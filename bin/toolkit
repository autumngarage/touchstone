#!/usr/bin/env bash
#
# toolkit — CLI for the shared engineering toolkit.
#
# Usage:
#   toolkit new <project-dir>          Create a new project with toolkit files
#   toolkit init [--no-setup]          Add toolkit to the current project
#   toolkit update                     Update current project to latest toolkit
#   toolkit update --dry-run           Show what would change without applying
#   toolkit sync                       Update all registered projects
#   toolkit sync --pull-first          Pull latest toolkit, then sync all projects
#   toolkit status                     Dashboard — health of all registered projects
#   toolkit version                    Show installed version
#   toolkit doctor                     Check health of toolkit installation
#   toolkit help                       Show this help
#
# Install:
#   brew tap henrymodisett/toolkit
#   brew install toolkit
#
set -euo pipefail

# Resolve TOOLKIT_ROOT — works whether installed via brew symlink or clone.
SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [ -h "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
TOOLKIT_ROOT="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"
export TOOLKIT_ROOT

# Source shared libraries.
source "$TOOLKIT_ROOT/lib/auto-update.sh"
source "$TOOLKIT_ROOT/lib/colors.sh"

# Auto-update check (throttled, non-blocking on failure).
toolkit_auto_update || true

# Helper: get toolkit version string.
toolkit_version_str() {
  cat "$TOOLKIT_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'
}

# Helper: get toolkit identifier for comparison (git SHA or version).
toolkit_current_id() {
  if [ -d "$TOOLKIT_ROOT/.git" ]; then
    git -C "$TOOLKIT_ROOT" rev-parse HEAD
  else
    toolkit_version_str
  fi
}

toolkit_current_id_short() {
  if [ -d "$TOOLKIT_ROOT/.git" ]; then
    git -C "$TOOLKIT_ROOT" rev-parse --short HEAD
  else
    toolkit_version_str
  fi
}

escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[\\/&]/\\&/g'
}

# --------------------------------------------------------------------------
# Subcommands
# --------------------------------------------------------------------------

cmd_new() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: toolkit new <project-dir> [--no-register] [--unsafe-paths path1,path2]" >&2
    exit 1
  fi
  case "${1:-}" in
    -h|--help)
      echo "Usage: toolkit new <project-dir> [--no-register] [--unsafe-paths path1,path2]"
      return 0
      ;;
  esac
  exec bash "$TOOLKIT_ROOT/bootstrap/new-project.sh" "$@"
}

cmd_init() {
  # Init the current directory — bootstrap + setup in one command.
  local run_setup=true
  local setup_existed=false
  local args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-setup)
        run_setup=false
        shift
        ;;
      -h|--help)
        echo "Usage: toolkit init [--no-setup] [--no-register] [--unsafe-paths path1,path2]"
        return 0
        ;;
      --no-register)
        args+=("$1")
        shift
        ;;
      --unsafe-paths)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --unsafe-paths requires a comma-separated value" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      *)
        echo "ERROR: unknown argument '$1'" >&2
        echo "Usage: toolkit init [--no-setup] [--no-register] [--unsafe-paths path1,path2]" >&2
        exit 1
        ;;
    esac
  done

  if [ -e "$(pwd)/setup.sh" ]; then
    setup_existed=true
  fi

  bash "$TOOLKIT_ROOT/bootstrap/new-project.sh" "$(pwd)" "${args[@]}"

  if [ "$run_setup" = true ] && [ -f "$(pwd)/setup.sh" ]; then
    if [ "$setup_existed" = true ]; then
      tk_warn "setup.sh already existed, so toolkit left it in place and did not run it."
      tk_dim "Run manually if desired: bash setup.sh"
      return 0
    fi
    echo ""
    bash "$(pwd)/setup.sh"
  fi
}

cmd_update() {
  exec bash "$TOOLKIT_ROOT/bootstrap/update-project.sh" "$@"
}

cmd_sync() {
  exec bash "$TOOLKIT_ROOT/bootstrap/sync-all.sh" "$@"
}

cmd_version() {
  local version
  version="$(toolkit_version_str)"
  tk_header "toolkit v${version:-unknown}"

  if command -v brew >/dev/null 2>&1 && brew list toolkit &>/dev/null; then
    tk_dim "installed via: brew"
    tk_dim "prefix: $(brew --prefix toolkit 2>/dev/null || echo unknown)"
  elif [ -d "$TOOLKIT_ROOT/.git" ]; then
    tk_dim "installed via: git clone"
    tk_dim "path: $TOOLKIT_ROOT"
    tk_dim "commit: $(git -C "$TOOLKIT_ROOT" rev-parse --short HEAD 2>/dev/null)"
  fi

  local projects_file="$HOME/.toolkit-projects"
  if [ -f "$projects_file" ]; then
    local count
    count="$(grep -c '[^[:space:]]' "$projects_file" 2>/dev/null || echo 0)"
    tk_dim "projects: $count registered"
  fi
}

cmd_status() {
  local version
  version="$(toolkit_version_str)"
  local current_id
  current_id="$(toolkit_current_id)"

  tk_header "Toolkit Status — v${version}"

  local projects_file="$HOME/.toolkit-projects"
  if [ ! -f "$projects_file" ]; then
    tk_warn "No projects registered. Run: toolkit new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue

    local name
    name="$(basename "$project_dir")"

    if [ ! -d "$project_dir" ]; then
      printf "  ${RED}✗${RESET} ${BOLD}%-20s${RESET} directory not found\n" "$name"
      continue
    fi

    # Gather project state.
    local proj_version
    proj_version="$(cat "$project_dir/.toolkit-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
    local synced=""
    if [ "$proj_version" = "$current_id" ]; then
      synced="${GREEN}synced${RESET}"
    else
      synced="${YELLOW}needs sync${RESET}"
    fi

    # Git state.
    local git_status=""
    if [ -d "$project_dir/.git" ]; then
      local dirty=""
      local unpushed=""
      local branch=""
      branch="$(git -C "$project_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"

      if [ -n "$(git -C "$project_dir" status --porcelain 2>/dev/null)" ]; then
        dirty="${YELLOW}dirty${RESET}"
      else
        dirty="${GREEN}clean${RESET}"
      fi

      local ahead
      ahead="$(git -C "$project_dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo "?")"
      if [ "$ahead" = "?" ] || [ "$ahead" = "0" ]; then
        unpushed=""
      else
        unpushed=" ${YELLOW}${ahead} unpushed${RESET}"
      fi

      git_status="${dirty}${unpushed} ${DIM}(${branch})${RESET}"
    else
      git_status="${DIM}not a git repo${RESET}"
    fi

    printf "  ${GREEN}✓${RESET} ${BOLD}%-20s${RESET} %b  %b\n" "$name" "$synced" "$git_status"
  done < "$projects_file"

  echo ""
}

cmd_doctor() {
  local version
  version="$(toolkit_version_str)"
  local issues=0

  tk_header "Toolkit Doctor"

  # Version.
  if [ -n "$version" ]; then
    tk_ok "Version: v${version}"
  else
    tk_fail "Version: MISSING"
    issues=$((issues + 1))
  fi

  # Required tools.
  for tool in git gh bash; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_fail "$tool: MISSING"
      issues=$((issues + 1))
    fi
  done

  # Recommended tools.
  for tool in pre-commit gitleaks shellcheck shfmt; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_warn "$tool: not installed (run setup.sh to install)"
      issues=$((issues + 1))
    fi
  done

  # Optional tools.
  if command -v codex >/dev/null 2>&1; then
    tk_ok "codex: $(command -v codex)"
  else
    tk_dim "codex: not installed (optional — npm install -g @openai/codex)"
  fi

  # Registered projects.
  tk_info "Projects"
  local projects_file="$HOME/.toolkit-projects"
  local current_id
  current_id="$(toolkit_current_id)"
  if [ -f "$projects_file" ]; then
    while IFS= read -r project_dir; do
      [ -z "$project_dir" ] && continue
      [[ "$project_dir" == \#* ]] && continue
      if [ -d "$project_dir" ]; then
        local proj_version
        proj_version="$(cat "$project_dir/.toolkit-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
        local name
        name="$(basename "$project_dir")"
        if [ "$proj_version" = "$current_id" ]; then
          tk_ok "$name — up to date"
        else
          tk_warn "$name — needs sync (run: toolkit sync)"
          issues=$((issues + 1))
        fi
      else
        tk_fail "$project_dir — directory not found"
        issues=$((issues + 1))
      fi
    done < "$projects_file"
  else
    tk_dim "No projects registered yet."
  fi

  # Latest release check.
  tk_info "Latest release"
  local latest
  latest="$(curl -fsSL --max-time 5 \
    "https://api.github.com/repos/henrymodisett/toolkit/releases/latest" 2>/dev/null \
    | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/')" || latest=""
  if [ -n "$latest" ]; then
    if [ "$version" = "$latest" ]; then
      tk_ok "v${latest} — you're current"
    else
      tk_warn "v${latest} available (you have v${version}). Run: brew upgrade toolkit"
      issues=$((issues + 1))
    fi
  else
    tk_dim "Couldn't check (network issue?)"
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "All good."
  else
    tk_warn "$issues issue(s) found."
  fi
  echo ""
}

cmd_list() {
  local projects_file="$HOME/.toolkit-projects"
  local current_id
  current_id="$(toolkit_current_id)"

  tk_header "Registered Projects"

  if [ ! -f "$projects_file" ] || [ ! -s "$projects_file" ]; then
    tk_dim "No projects registered. Run: toolkit new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue
    local name
    name="$(basename "$project_dir")"
    if [ -d "$project_dir" ]; then
      local proj_version
      proj_version="$(cat "$project_dir/.toolkit-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
      if [ "$proj_version" = "$current_id" ]; then
        tk_ok "$name  ${DIM}$project_dir${RESET}"
      else
        tk_warn "$name  ${DIM}$project_dir${RESET}  ${YELLOW}(needs sync)${RESET}"
      fi
    else
      tk_fail "$name  ${DIM}$project_dir${RESET}  ${RED}(not found)${RESET}"
    fi
  done < "$projects_file"
  echo ""
}

cmd_unregister() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: toolkit unregister <project-path-or-name>" >&2
    exit 1
  fi

  local projects_file="$HOME/.toolkit-projects"
  if [ ! -f "$projects_file" ]; then
    tk_fail "No projects file found."
    return 1
  fi

  # Match by full path or basename.
  local matched=false
  local tmp_file
  tmp_file="$(mktemp)"
  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    if [ "$project_dir" = "$target" ] || [ "$(basename "$project_dir")" = "$target" ]; then
      tk_ok "Unregistered: $project_dir"
      matched=true
    else
      echo "$project_dir" >> "$tmp_file"
    fi
  done < "$projects_file"
  mv "$tmp_file" "$projects_file"

  if [ "$matched" = false ]; then
    tk_fail "No project matching '$target' found in registry."
    return 1
  fi
}

cmd_diff() {
  tk_header "Template Diff"
  tk_dim "Comparing project files against latest toolkit templates"
  echo ""

  local has_diff=false
  local pairs=(
    "CLAUDE.md:templates/CLAUDE.md"
    "AGENTS.md:templates/AGENTS.md"
    ".pre-commit-config.yaml:templates/pre-commit-config.yaml"
    ".codex-review.toml:hooks/codex-review.config.example.toml"
  )

  for pair in "${pairs[@]}"; do
    local project_file="${pair%%:*}"
    local template_file="${pair##*:}"
    local template_path="$TOOLKIT_ROOT/$template_file"

    if [ ! -f "$project_file" ]; then
      tk_dim "$project_file — not found (skipped)"
      continue
    fi
    if [ ! -f "$template_path" ]; then
      continue
    fi

    if diff -q "$project_file" "$template_path" >/dev/null 2>&1; then
      tk_ok "$project_file — matches template"
    else
      has_diff=true
      echo "${BOLD}--- $project_file (project)${RESET}"
      echo "${BOLD}+++ $template_file (toolkit template)${RESET}"
      diff -u "$project_file" "$template_path" 2>/dev/null | tail -n +3 || true
      echo ""
    fi
  done

  if [ "$has_diff" = false ]; then
    tk_ok "All project-owned files match templates."
  fi
  echo ""
}

cmd_adr() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      tk_header "Architecture Decision Records"
      if [ -d "docs/adr" ] && ls docs/adr/*.md >/dev/null 2>&1; then
        for f in docs/adr/[0-9]*.md; do
          local num title
          num="$(basename "$f" .md | grep -o '^[0-9]*')"
          title="$(head -1 "$f" | sed 's/^#* *//' | sed "s/^ADR-$num: //")"
          printf "  ${BOLD}ADR-%s${RESET}: %s\n" "$num" "$title"
        done
      else
        tk_dim "No ADRs found. Create one with: toolkit adr \"Title of decision\""
      fi
      echo ""
      ;;
    "")
      echo "Usage:" >&2
      echo "  toolkit adr \"Title of decision\"    Create a new ADR" >&2
      echo "  toolkit adr list                    List all ADRs" >&2
      exit 1
      ;;
    *)
      # Create a new ADR. The subcmd and remaining args form the title.
      local title="$subcmd $*"
      title="$(echo "$title" | sed 's/[[:space:]]*$//')"

      mkdir -p docs/adr

      # Find next number.
      local last_num=0
      if ls docs/adr/[0-9]*.md >/dev/null 2>&1; then
        last_num="$(ls docs/adr/[0-9]*.md | sed 's/.*\///' | grep -o '^[0-9]*' | sort -n | tail -1)"
      fi
      local next_num=$((10#$last_num + 1))
      local padded
      padded="$(printf "%04d" "$next_num")"

      local slug
      slug="$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')"
      local filename="docs/adr/${padded}-${slug}.md"

      local today
      today="$(date +%Y-%m-%d)"

      # Copy template and fill in.
      cp "$TOOLKIT_ROOT/templates/adr/0000-template.md" "$filename"
      sed -i '' "s/NNNN/$padded/g" "$filename"
      escaped_title="$(escape_sed_replacement "$title")"
      sed -i '' "s/TITLE/$escaped_title/g" "$filename"
      sed -i '' "s/DATE/$today/g" "$filename"

      tk_ok "Created: $filename"
      ;;
  esac
}

cmd_release() {
  source "$TOOLKIT_ROOT/lib/release.sh"

  local bump_type="minor"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --major) bump_type="major"; shift ;;
      --minor) bump_type="minor"; shift ;;
      --patch) bump_type="patch"; shift ;;
      *) echo "Usage: toolkit release [--major|--minor|--patch]" >&2; exit 1 ;;
    esac
  done

  toolkit_release "$bump_type"
}

cmd_help() {
  tk_header "toolkit — shared engineering toolkit"
  echo "  ${BOLD}Project commands:${RESET}"
  printf "    ${BOLD}toolkit init${RESET} [--no-setup]      Add toolkit to the current project\n"
  printf "    ${BOLD}toolkit new${RESET} <dir>              Bootstrap a new project from scratch\n"
  printf "    ${BOLD}toolkit update${RESET}                 Update current project to latest\n"
  printf "    ${BOLD}toolkit update${RESET} --dry-run       Preview what would change\n"
  printf "    ${BOLD}toolkit sync${RESET}                   Update all registered projects\n"
  printf "    ${BOLD}toolkit sync${RESET} --pull-first      Pull latest toolkit first\n"
  printf "    ${BOLD}toolkit diff${RESET}                   Compare project files vs templates\n"
  printf "    ${BOLD}toolkit adr${RESET} \"Title\"            Create an Architecture Decision Record\n"
  printf "    ${BOLD}toolkit adr${RESET} list               List all ADRs\n"
  echo ""
  echo "  ${BOLD}Registry commands:${RESET}"
  printf "    ${BOLD}toolkit list${RESET}                   Show registered projects\n"
  printf "    ${BOLD}toolkit unregister${RESET} <name>      Remove a project from registry\n"
  printf "    ${BOLD}toolkit status${RESET}                 Dashboard — all projects at a glance\n"
  echo ""
  echo "  ${BOLD}Toolkit commands:${RESET}"
  printf "    ${BOLD}toolkit doctor${RESET}                 Check installation health\n"
  printf "    ${BOLD}toolkit version${RESET}                Show installed version\n"
  printf "    ${BOLD}toolkit release${RESET} [--patch]      Cut a new toolkit release\n"
  printf "    ${BOLD}toolkit help${RESET}                   Show this help\n"
  echo ""
  printf "  Install: ${DIM}brew tap henrymodisett/toolkit && brew install toolkit${RESET}\n"
  echo ""
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  new)          cmd_new "$@" ;;
  init)         cmd_init "$@" ;;
  update)       cmd_update "$@" ;;
  sync)         cmd_sync "$@" ;;
  status)       cmd_status ;;
  list|ls)      cmd_list ;;
  unregister)   cmd_unregister "$@" ;;
  diff)         cmd_diff ;;
  adr)          cmd_adr "$@" ;;
  release)      cmd_release "$@" ;;
  version)      cmd_version ;;
  doctor)       cmd_doctor ;;
  help|-h|--help) cmd_help ;;
  *)
    printf "${RED}Unknown command: $COMMAND${RESET}\n" >&2
    echo "Run 'toolkit help' for usage." >&2
    exit 1
    ;;
esac
