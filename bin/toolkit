#!/usr/bin/env bash
#
# toolkit — CLI for the shared engineering toolkit.
#
# Usage:
#   toolkit new <project-dir>          Create a new project with toolkit files
#   toolkit update                     Update current project to latest toolkit
#   toolkit update --dry-run           Show what would change without applying
#   toolkit sync                       Update all registered projects
#   toolkit sync --pull-first          Pull latest toolkit, then sync all projects
#   toolkit status                     Dashboard — health of all registered projects
#   toolkit version                    Show installed version
#   toolkit doctor                     Check health of toolkit installation
#   toolkit help                       Show this help
#
# Install:
#   brew tap henrymodisett/toolkit
#   brew install toolkit
#
set -euo pipefail

# Resolve TOOLKIT_ROOT — works whether installed via brew or running from clone.
REAL_PATH="$(python3 -c "import os; print(os.path.realpath('$0'))")"
TOOLKIT_ROOT="$(cd "$(dirname "$REAL_PATH")/.." && pwd)"
export TOOLKIT_ROOT

# Source shared libraries.
source "$TOOLKIT_ROOT/lib/auto-update.sh"
source "$TOOLKIT_ROOT/lib/colors.sh"

# Auto-update check (throttled, non-blocking on failure).
toolkit_auto_update || true

# Helper: get toolkit version string.
toolkit_version_str() {
  cat "$TOOLKIT_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'
}

# Helper: get toolkit identifier for comparison (git SHA or version).
toolkit_current_id() {
  if [ -d "$TOOLKIT_ROOT/.git" ]; then
    git -C "$TOOLKIT_ROOT" rev-parse HEAD
  else
    toolkit_version_str
  fi
}

toolkit_current_id_short() {
  if [ -d "$TOOLKIT_ROOT/.git" ]; then
    git -C "$TOOLKIT_ROOT" rev-parse --short HEAD
  else
    toolkit_version_str
  fi
}

# --------------------------------------------------------------------------
# Subcommands
# --------------------------------------------------------------------------

cmd_new() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: toolkit new <project-dir> [--no-register]" >&2
    exit 1
  fi
  exec bash "$TOOLKIT_ROOT/bootstrap/new-project.sh" "$@"
}

cmd_update() {
  exec bash "$TOOLKIT_ROOT/bootstrap/update-project.sh" "$@"
}

cmd_sync() {
  exec bash "$TOOLKIT_ROOT/bootstrap/sync-all.sh" "$@"
}

cmd_version() {
  local version
  version="$(toolkit_version_str)"
  tk_header "toolkit v${version:-unknown}"

  if command -v brew >/dev/null 2>&1 && brew list toolkit &>/dev/null; then
    tk_dim "installed via: brew"
    tk_dim "prefix: $(brew --prefix toolkit 2>/dev/null || echo unknown)"
  elif [ -d "$TOOLKIT_ROOT/.git" ]; then
    tk_dim "installed via: git clone"
    tk_dim "path: $TOOLKIT_ROOT"
    tk_dim "commit: $(git -C "$TOOLKIT_ROOT" rev-parse --short HEAD 2>/dev/null)"
  fi

  local projects_file="$HOME/.toolkit-projects"
  if [ -f "$projects_file" ]; then
    local count
    count="$(grep -c '[^[:space:]]' "$projects_file" 2>/dev/null || echo 0)"
    tk_dim "projects: $count registered"
  fi
}

cmd_status() {
  local version
  version="$(toolkit_version_str)"
  local current_id
  current_id="$(toolkit_current_id)"

  tk_header "Toolkit Status — v${version}"

  local projects_file="$HOME/.toolkit-projects"
  if [ ! -f "$projects_file" ]; then
    tk_warn "No projects registered. Run: toolkit new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue

    local name
    name="$(basename "$project_dir")"

    if [ ! -d "$project_dir" ]; then
      printf "  ${RED}✗${RESET} ${BOLD}%-20s${RESET} directory not found\n" "$name"
      continue
    fi

    # Gather project state.
    local proj_version
    proj_version="$(cat "$project_dir/.toolkit-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
    local synced=""
    if [ "$proj_version" = "$current_id" ]; then
      synced="${GREEN}synced${RESET}"
    else
      synced="${YELLOW}needs sync${RESET}"
    fi

    # Git state.
    local git_status=""
    if [ -d "$project_dir/.git" ]; then
      local dirty=""
      local unpushed=""
      local branch=""
      branch="$(git -C "$project_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"

      if [ -n "$(git -C "$project_dir" status --porcelain 2>/dev/null)" ]; then
        dirty="${YELLOW}dirty${RESET}"
      else
        dirty="${GREEN}clean${RESET}"
      fi

      local ahead
      ahead="$(git -C "$project_dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo "?")"
      if [ "$ahead" = "?" ] || [ "$ahead" = "0" ]; then
        unpushed=""
      else
        unpushed=" ${YELLOW}${ahead} unpushed${RESET}"
      fi

      git_status="${dirty}${unpushed} ${DIM}(${branch})${RESET}"
    else
      git_status="${DIM}not a git repo${RESET}"
    fi

    printf "  ${GREEN}✓${RESET} ${BOLD}%-20s${RESET} %b  %b\n" "$name" "$synced" "$git_status"
  done < "$projects_file"

  echo ""
}

cmd_doctor() {
  local version
  version="$(toolkit_version_str)"
  local issues=0

  tk_header "Toolkit Doctor"

  # Version.
  if [ -n "$version" ]; then
    tk_ok "Version: v${version}"
  else
    tk_fail "Version: MISSING"
    issues=$((issues + 1))
  fi

  # Required tools.
  for tool in git gh bash; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_fail "$tool: MISSING"
      issues=$((issues + 1))
    fi
  done

  # Recommended tools.
  for tool in pre-commit gitleaks shellcheck shfmt; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_warn "$tool: not installed (run setup.sh to install)"
      issues=$((issues + 1))
    fi
  done

  # Optional tools.
  if command -v codex >/dev/null 2>&1; then
    tk_ok "codex: $(command -v codex)"
  else
    tk_dim "codex: not installed (optional — npm install -g @openai/codex)"
  fi

  # Registered projects.
  tk_info "Projects"
  local projects_file="$HOME/.toolkit-projects"
  local current_id
  current_id="$(toolkit_current_id)"
  if [ -f "$projects_file" ]; then
    while IFS= read -r project_dir; do
      [ -z "$project_dir" ] && continue
      [[ "$project_dir" == \#* ]] && continue
      if [ -d "$project_dir" ]; then
        local proj_version
        proj_version="$(cat "$project_dir/.toolkit-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
        local name
        name="$(basename "$project_dir")"
        if [ "$proj_version" = "$current_id" ]; then
          tk_ok "$name — up to date"
        else
          tk_warn "$name — needs sync (run: toolkit sync)"
          issues=$((issues + 1))
        fi
      else
        tk_fail "$project_dir — directory not found"
        issues=$((issues + 1))
      fi
    done < "$projects_file"
  else
    tk_dim "No projects registered yet."
  fi

  # Latest release check.
  tk_info "Latest release"
  local latest
  latest="$(curl -fsSL --max-time 5 \
    "https://api.github.com/repos/henrymodisett/toolkit/releases/latest" 2>/dev/null \
    | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/')" || latest=""
  if [ -n "$latest" ]; then
    if [ "$version" = "$latest" ]; then
      tk_ok "v${latest} — you're current"
    else
      tk_warn "v${latest} available (you have v${version}). Run: brew upgrade toolkit"
      issues=$((issues + 1))
    fi
  else
    tk_dim "Couldn't check (network issue?)"
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "All good."
  else
    tk_warn "$issues issue(s) found."
  fi
  echo ""
}

cmd_help() {
  tk_header "toolkit — shared engineering toolkit"
  printf "  ${BOLD}toolkit new${RESET} <dir>              Bootstrap a new project\n"
  printf "  ${BOLD}toolkit update${RESET}                 Update current project to latest toolkit\n"
  printf "  ${BOLD}toolkit update${RESET} --dry-run       Preview what would change\n"
  printf "  ${BOLD}toolkit sync${RESET}                   Update all registered projects\n"
  printf "  ${BOLD}toolkit sync${RESET} --pull-first      Pull latest toolkit first, then sync\n"
  printf "  ${BOLD}toolkit status${RESET}                 Dashboard — health of all projects\n"
  printf "  ${BOLD}toolkit doctor${RESET}                 Check toolkit installation health\n"
  printf "  ${BOLD}toolkit version${RESET}                Show installed version\n"
  printf "  ${BOLD}toolkit help${RESET}                   Show this help\n"
  echo ""
  printf "  Install: ${DIM}brew tap henrymodisett/toolkit && brew install toolkit${RESET}\n"
  echo ""
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  new)      cmd_new "$@" ;;
  update)   cmd_update "$@" ;;
  sync)     cmd_sync "$@" ;;
  status)   cmd_status ;;
  version)  cmd_version ;;
  doctor)   cmd_doctor ;;
  help|-h|--help) cmd_help ;;
  *)
    printf "${RED}Unknown command: $COMMAND${RESET}\n" >&2
    echo "Run 'toolkit help' for usage." >&2
    exit 1
    ;;
esac
