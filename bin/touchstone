#!/usr/bin/env bash
#
# touchstone — CLI for the shared engineering starter kit.
#
# Usage:
#   touchstone new <project-dir>          Create a new project with touchstone files
#   touchstone init [--no-setup] [--no-ship] [--type node|python|swift|rust|go|generic|auto] [--reviewer codex|claude|gemini|local|auto|none]
#                                      Add touchstone to the current project
#   touchstone run <task>                  Run profile task: lint, test, build, typecheck, validate
#   touchstone update                     Update current project to latest touchstone
#   touchstone update --dry-run           Show what would change without applying
#   touchstone update --check             Report whether current project needs update
#   touchstone sync                       Update all registered projects
#   touchstone sync --pull-first          Pull latest touchstone, then sync all projects
#   touchstone status                     Dashboard — health of all registered projects
#   touchstone version                    Show installed version
#   touchstone doctor                     Check health of touchstone installation
#   touchstone help                       Show this help
#
# Install:
#   brew tap autumngarage/touchstone
#   brew install touchstone
#
set -euo pipefail

# Resolve TOUCHSTONE_ROOT — works whether installed via brew symlink or clone.
SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [ -h "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
TOUCHSTONE_ROOT="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"
export TOUCHSTONE_ROOT

# Source shared libraries.
source "$TOUCHSTONE_ROOT/lib/auto-update.sh"
source "$TOUCHSTONE_ROOT/lib/colors.sh"
source "$TOUCHSTONE_ROOT/lib/ui.sh"

# Auto-update check (throttled, non-blocking on failure).
touchstone_auto_update || true

# Helper: get touchstone version string.
touchstone_version_str() {
  cat "$TOUCHSTONE_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'
}

# Helper: get touchstone identifier for comparison (git SHA or version).
touchstone_current_id() {
  if [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    git -C "$TOUCHSTONE_ROOT" rev-parse HEAD
  else
    touchstone_version_str
  fi
}

touchstone_current_id_short() {
  if [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    git -C "$TOUCHSTONE_ROOT" rev-parse --short HEAD
  else
    touchstone_version_str
  fi
}

escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[\\/&]/\\&/g'
}

# --------------------------------------------------------------------------
# Subcommands
# --------------------------------------------------------------------------

cmd_new() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: touchstone new <project-dir> [--no-register] [--type node|python|swift|rust|go|generic|auto] [--unsafe-paths path1,path2] [--reviewer codex|claude|gemini|local|auto|none] [--review-routing all-hosted|all-local|small-local] [--gitbutler|--no-gitbutler]" >&2
    exit 1
  fi
  case "${1:-}" in
    -h|--help)
      echo "Usage: touchstone new <project-dir> [--no-register] [--type node|python|swift|rust|go|generic|auto] [--unsafe-paths path1,path2] [--reviewer codex|claude|gemini|local|auto|none] [--review-routing all-hosted|all-local|small-local] [--small-review-lines N] [--gitbutler|--no-gitbutler] [--gitbutler-mcp|--no-gitbutler-mcp]"
      return 0
      ;;
  esac
  exec bash "$TOUCHSTONE_ROOT/bootstrap/new-project.sh" "$@"
}

cmd_init() {
  # Init the current directory — bootstrap + setup in one command.
  local run_setup=true
  local setup_existed=false
  local ship_upgrade=true
  local args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-setup)
        run_setup=false
        shift
        ;;
      --ship)
        ship_upgrade=true
        shift
        ;;
      --no-ship)
        ship_upgrade=false
        shift
        ;;
      -h|--help)
        echo "Usage: touchstone init [--no-setup] [--no-ship] [--type node|python|swift|rust|go|generic|auto] [--no-register] [--unsafe-paths path1,path2] [--reviewer codex|claude|gemini|local|auto|none] [--review-routing all-hosted|all-local|small-local] [--small-review-lines N] [--gitbutler|--no-gitbutler] [--gitbutler-mcp|--no-gitbutler-mcp]"
        return 0
        ;;
      --type)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --type requires a value (node, python, swift, rust, go, generic, auto)" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --no-register)
        args+=("$1")
        shift
        ;;
      --unsafe-paths)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --unsafe-paths requires a comma-separated value" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --reviewer|--local-review-command|--review-routing|--small-review-lines|--git-workflow)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: $1 requires a value" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --no-ai-review|--no-review|--review-assist|--no-review-assist|--review-autofix|--no-review-autofix|--gitbutler|--no-gitbutler|--gitbutler-mcp|--no-gitbutler-mcp)
        args+=("$1")
        shift
        ;;
      *)
        echo "ERROR: unknown argument '$1'" >&2
        echo "Usage: touchstone init [--no-setup] [--no-ship] [--type node|python|swift|rust|go|generic|auto] [--no-register] [--unsafe-paths path1,path2] [--reviewer codex|claude|gemini|local|auto|none] [--review-routing all-hosted|all-local|small-local] [--gitbutler|--no-gitbutler]" >&2
        exit 1
        ;;
    esac
  done

  if [ -e "$(pwd)/setup.sh" ]; then
    setup_existed=true
  fi

  # State detection: fresh | current | outdated | legacy-toolkit. Determines
  # whether init bootstraps, reconciles, or delegates to the update flow.
  local project_dir installed_id current_id init_state="fresh"
  project_dir="$(pwd)"

  if [ -f "$project_dir/.toolkit-version" ] && [ -f "$project_dir/.touchstone-version" ]; then
    tk_fail "Migration conflict: both .toolkit-version and .touchstone-version are present in $project_dir"
    tk_dim "  Fix: rm .toolkit-version   (touchstone has already been installed here)"
    return 1
  elif [ -f "$project_dir/.toolkit-version" ]; then
    init_state="legacy-toolkit"
  elif [ -f "$project_dir/.touchstone-version" ]; then
    installed_id="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "")"
    current_id="$(touchstone_current_id)"
    if [ "$installed_id" = "$current_id" ]; then
      init_state="current"
    else
      init_state="outdated"
    fi
  fi

  case "$init_state" in
    legacy-toolkit)
      tk_fail "Legacy .toolkit-version found in $project_dir"
      tk_dim "Run: touchstone migrate-from-toolkit"
      tk_dim "Then re-run: touchstone init"
      return 1
      ;;
    outdated)
      tk_header "Touchstone init — upgrading"
      tk_dim "  installed: ${installed_id:0:12}"
      tk_dim "  current:   ${current_id:0:12}"
      local update_args=()
      if [ "$ship_upgrade" = true ]; then
        tk_info "Delegating to 'touchstone update --ship' (branch + commit + auto-merge PR)"
        update_args+=("--ship")
      else
        tk_info "Delegating to 'touchstone update' (branch + commit so the upgrade is reviewable)"
      fi
      echo ""
      exec bash "$TOUCHSTONE_ROOT/bootstrap/update-project.sh" "${update_args[@]}"
      ;;
  esac

  # Fresh init: greet with the branded hero so setup feels like setup.
  tk_hero "setting up this project"

  bash "$TOUCHSTONE_ROOT/bootstrap/new-project.sh" "$project_dir" "${args[@]}"

  # Only fresh init runs setup.sh automatically. Reconciling an existing repo
  # must not re-trigger machine-wide dev-tool installs or interactive prompts
  # just because the user happened to delete setup.sh before re-running init.
  if [ "$init_state" = "fresh" ] && [ "$run_setup" = true ] && [ -f "$project_dir/setup.sh" ]; then
    if [ "$setup_existed" = true ]; then
      tk_warn "setup.sh already existed, so touchstone left it in place and did not run it."
      tk_dim "Run manually if desired: bash setup.sh"
      return 0
    fi
    echo ""
    bash "$project_dir/setup.sh"
  fi
}

cmd_update() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/update-project.sh" "$@"
}

cmd_migrate_from_toolkit() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/migrate-from-toolkit.sh" "$@"
}

cmd_sync() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/sync-all.sh" "$@"
}

cmd_run() {
  exec bash "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" "$@"
}

cmd_detect() {
  exec bash "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" detect
}

cmd_version() {
  local version
  version="$(touchstone_version_str)"
  tk_header "touchstone v${version:-unknown}"

  if command -v brew >/dev/null 2>&1 && brew list touchstone &>/dev/null; then
    tk_dim "installed via: brew"
    tk_dim "prefix: $(brew --prefix touchstone 2>/dev/null || echo unknown)"
  elif [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    tk_dim "installed via: git clone"
    tk_dim "path: $TOUCHSTONE_ROOT"
    tk_dim "commit: $(git -C "$TOUCHSTONE_ROOT" rev-parse --short HEAD 2>/dev/null)"
  fi

  local projects_file="$HOME/.touchstone-projects"
  if [ -f "$projects_file" ]; then
    local count
    count="$(grep -c '[^[:space:]]' "$projects_file" 2>/dev/null || echo 0)"
    tk_dim "projects: $count registered"
  fi
}

cmd_status() {
  local version
  version="$(touchstone_version_str)"
  local current_id
  current_id="$(touchstone_current_id)"

  tk_header "Touchstone Status — v${version}"

  local projects_file="$HOME/.touchstone-projects"
  if [ ! -f "$projects_file" ]; then
    tk_warn "No projects registered. Run: touchstone new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue

    local name
    name="$(basename "$project_dir")"

    if [ ! -d "$project_dir" ]; then
      printf "  ${RED}✗${RESET} ${BOLD}%-20s${RESET} directory not found\n" "$name"
      continue
    fi

    # Gather project state.
    local proj_version
    proj_version="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
    local synced=""
    if [ "$proj_version" = "$current_id" ]; then
      synced="${GREEN}synced${RESET}"
    else
      synced="${YELLOW}needs sync${RESET}"
    fi

    # Git state.
    local git_status=""
    if [ -d "$project_dir/.git" ]; then
      local dirty=""
      local unpushed=""
      local branch=""
      branch="$(git -C "$project_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"

      if [ -n "$(git -C "$project_dir" status --porcelain 2>/dev/null)" ]; then
        dirty="${YELLOW}dirty${RESET}"
      else
        dirty="${GREEN}clean${RESET}"
      fi

      local ahead
      ahead="$(git -C "$project_dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo "?")"
      if [ "$ahead" = "?" ] || [ "$ahead" = "0" ]; then
        unpushed=""
      else
        unpushed=" ${YELLOW}${ahead} unpushed${RESET}"
      fi

      git_status="${dirty}${unpushed} ${DIM}(${branch})${RESET}"
    else
      git_status="${DIM}not a git repo${RESET}"
    fi

    printf "  ${GREEN}✓${RESET} ${BOLD}%-20s${RESET} %b  %b\n" "$name" "$synced" "$git_status"
  done < "$projects_file"

  echo ""
}

cmd_doctor_project() {
  local project_dir issues=0
  project_dir="$(pwd)"

  tk_header "Touchstone Project Doctor — $(basename "$project_dir")"

  # 1. Is this a touchstone-managed project? Reject migration-conflict state first —
  # a project with both files is mid-migration and must not be reported healthy.
  if [ -f "$project_dir/.toolkit-version" ] && [ -f "$project_dir/.touchstone-version" ]; then
    tk_fail "Migration conflict: both .toolkit-version and .touchstone-version present"
    tk_dim "  Fix: rm .toolkit-version   (touchstone has already been installed)"
    echo ""
    return 1
  fi
  if [ ! -f "$project_dir/.touchstone-version" ]; then
    if [ -f "$project_dir/.toolkit-version" ]; then
      tk_fail "Legacy .toolkit-version found"
      tk_dim "  Fix: touchstone migrate-from-toolkit"
      echo ""
      return 1
    fi
    tk_fail "Not a touchstone project (no .touchstone-version)"
    tk_dim "  Fix: touchstone init"
    echo ""
    return 1
  fi

  local installed_id current_id
  installed_id="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "")"
  current_id="$(touchstone_current_id)"
  if [ "$installed_id" = "$current_id" ]; then
    tk_ok "touchstone version matches: ${installed_id:0:12}"
  else
    tk_warn "touchstone out of date (installed ${installed_id:0:12}, current ${current_id:0:12})"
    tk_dim "  Fix: touchstone update"
    issues=$((issues + 1))
  fi

  # 2. Git hooks installed? This is the footgun that silently ungates a repo.
  # Verify three separate failure modes because Git silently no-ops on any of them:
  #   - file absent → hook never runs
  #   - file present but not executable → Git skips it (same effect as absent)
  #   - file executable but not the pre-commit-framework shim → another hook
  #     framework replaced it; pushes proceed without Codex review / validate.
  if [ ! -f "$project_dir/.pre-commit-config.yaml" ]; then
    tk_warn ".pre-commit-config.yaml is missing"
    tk_dim "  Fix: touchstone init  (reconciles missing templates)"
    issues=$((issues + 1))
  else
    if [ -f "$project_dir/.git/hooks/pre-commit" ] && [ -f "$project_dir/.git/hooks/pre-push" ]; then
      if [ ! -x "$project_dir/.git/hooks/pre-commit" ] || [ ! -x "$project_dir/.git/hooks/pre-push" ]; then
        tk_fail "git hooks exist but are not executable — Git will skip them, repo is ungated"
        tk_dim "  Fix: chmod +x $project_dir/.git/hooks/pre-commit $project_dir/.git/hooks/pre-push"
        issues=$((issues + 1))
      elif grep -q 'pre-commit\.com' "$project_dir/.git/hooks/pre-push" 2>/dev/null \
           && grep -q 'pre-commit\.com' "$project_dir/.git/hooks/pre-commit" 2>/dev/null; then
        tk_ok "git hooks installed (.git/hooks/pre-commit, .git/hooks/pre-push)"
      else
        tk_warn "git hook files exist but aren't the pre-commit-framework shim"
        tk_dim "  Another hook framework may have replaced them."
        tk_dim "  Fix: pre-commit install --hook-type pre-commit --hook-type pre-push"
        issues=$((issues + 1))
      fi
    else
      tk_fail "git hooks NOT installed — repo is ungated"
      if command -v pre-commit >/dev/null 2>&1; then
        tk_dim "  Fix: touchstone init   (idempotent — reinstalls missing hooks)"
      else
        tk_dim "  Fix: brew install pre-commit && touchstone init"
      fi
      issues=$((issues + 1))
    fi
  fi

  # 3. Manifest files present?
  if [ -f "$project_dir/.touchstone-manifest" ]; then
    local missing=0 line
    while IFS= read -r line || [ -n "$line" ]; do
      line="${line#"${line%%[![:space:]]*}"}"
      line="${line%"${line##*[![:space:]]}"}"
      [ -z "$line" ] && continue
      case "$line" in \#*) continue ;; esac
      if [ ! -e "$project_dir/$line" ]; then
        tk_fail "manifest file missing: $line"
        missing=$((missing + 1))
      fi
    done < "$project_dir/.touchstone-manifest"
    if [ "$missing" -eq 0 ]; then
      tk_ok "manifest files all present"
    else
      tk_dim "  Fix: touchstone init  (reconciles missing files)"
      issues=$((issues + missing))
    fi
  else
    tk_warn ".touchstone-manifest missing"
    tk_dim "  Fix: touchstone init"
    issues=$((issues + 1))
  fi

  # 4. Scripts executable?
  if [ -d "$project_dir/scripts" ]; then
    local not_executable=0 script
    for script in "$project_dir/scripts/"*.sh; do
      [ -f "$script" ] || continue
      if [ ! -x "$script" ]; then
        tk_fail "not executable: scripts/$(basename "$script")"
        not_executable=$((not_executable + 1))
      fi
    done
    if [ "$not_executable" -eq 0 ]; then
      tk_ok "scripts are executable"
    else
      tk_dim "  Fix: chmod +x $project_dir/scripts/*.sh"
      issues=$((issues + not_executable))
    fi
  fi

  # 5. Registered in ~/.touchstone-projects?  Informational — 'touchstone sync'
  # and 'touchstone list' depend on it, but the repo is still functionally gated.
  local projects_file="$HOME/.touchstone-projects"
  if [ -f "$projects_file" ] && grep -qxF "$project_dir" "$projects_file" 2>/dev/null; then
    tk_ok "registered in ~/.touchstone-projects"
  else
    tk_dim "not in ~/.touchstone-projects (touchstone sync won't update this project)"
    tk_dim "  Fix: echo \"$project_dir\" >> $projects_file"
  fi

  # 6. Optional — Codex review config present?
  if [ -f "$project_dir/.codex-review.toml" ]; then
    tk_ok ".codex-review.toml present"
  else
    tk_dim ".codex-review.toml not found (optional — configures AI review)"
  fi

  # 7. Profile-aware test-surface and tooling gap checks.
  # touchstone-run.sh validate silently skips when test files / linters are
  # absent (correct runtime UX). doctor is where those gaps become visible.
  local profile=""
  if [ -f "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" ]; then
    profile="$(cd "$project_dir" && bash "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" detect 2>/dev/null \
      | sed -n 's/^project_type=//p' | head -1)"
  fi
  profile="${profile:-generic}"

  # 7a. Test presence — informational nudge, not a blocking issue. An override
  # of test_command or validate_command means the project runs custom logic,
  # so the profile heuristic would be misleading — skip it.
  if _touchstone_config_has_override "$project_dir" test_command \
     || _touchstone_config_has_override "$project_dir" validate_command; then
    tk_dim "tests: overridden via .touchstone-config"
  elif _touchstone_profile_has_tests "$profile" "$project_dir"; then
    tk_ok "tests: found for profile '$profile'"
  elif [ "$profile" = "generic" ]; then
    tk_dim "tests: profile is 'generic' — touchstone runs whatever test_command you set"
  else
    tk_dim "tests: not found for profile '$profile' (runner will skip, not fail)"
    tk_dim "  See: touchstone run test  |  create one test to get real coverage"
  fi

  # 7b. Profile lint tool on PATH — a real gap because silent-skip at
  # runtime means lint issues merge uncaught. Honor lint_command / validate_command
  # overrides: when the project replaces the profile default, a missing profile
  # linter isn't a gap, it's unused.
  local lint_overridden=false
  if _touchstone_config_has_override "$project_dir" lint_command \
     || _touchstone_config_has_override "$project_dir" validate_command; then
    lint_overridden=true
  fi
  case "$profile" in
    python)
      if [ "$lint_overridden" = true ]; then
        tk_dim "lint: overridden via .touchstone-config"
      elif command -v ruff >/dev/null 2>&1; then
        tk_ok "ruff: on PATH"
      else
        tk_warn "ruff not on PATH — lint silently skips on every pre-push"
        tk_dim "  Fix: brew install ruff   (or: uv tool install ruff)"
        issues=$((issues + 1))
      fi
      ;;
    node)
      if [ "$lint_overridden" = true ]; then
        tk_dim "lint: overridden via .touchstone-config"
      elif [ -f "$project_dir/package.json" ] && grep -q '"lint"[[:space:]]*:' "$project_dir/package.json"; then
        tk_ok "package.json: lint script configured"
      else
        tk_dim "package.json has no 'lint' script — lint silently skips on every pre-push"
        tk_dim "  Fix: add a \"lint\" entry under \"scripts\" in package.json"
      fi
      ;;
    swift)
      if [ "$lint_overridden" = true ]; then
        tk_dim "lint: overridden via .touchstone-config"
      elif command -v swift-format >/dev/null 2>&1; then
        tk_ok "swift-format: on PATH"
      else
        tk_warn "swift-format not on PATH — lint silently skips on every pre-push"
        tk_dim "  Fix: brew install swift-format"
        issues=$((issues + 1))
      fi
      ;;
    rust|go|generic|*)
      : # rust tools ship with rustup; go vet is built-in; generic has no default
      ;;
  esac

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "Project is fully armed."
    echo ""
    return 0
  fi
  tk_warn "$issues issue(s) found. See fixes above, or run: touchstone init"
  echo ""
  return 1
}

# Report whether .touchstone-config assigns a non-empty value to the given key.
# Used to suppress profile-default doctor checks when a project has overridden
# the runner's behavior — otherwise doctor false-positives on correct configs.
_touchstone_config_has_override() {
  local dir="$1" key="$2"
  [ -f "$dir/.touchstone-config" ] || return 1
  # Match "key = value" where value has at least one non-space character.
  # Skips commented-out lines ("# key=...") and empty assignments ("key=").
  grep -Eq "^[[:space:]]*${key}[[:space:]]*=[[:space:]]*[^[:space:]#]" "$dir/.touchstone-config"
}

# Profile-aware test-presence heuristic. Matches typical layout conventions
# without running the language's test discovery — speed matters here, and the
# check is a nudge, not an authoritative answer.
_touchstone_profile_has_tests() {
  local profile="$1" dir="$2" matches
  case "$profile" in
    python)
      [ -d "$dir/tests" ] && return 0
      matches="$(find "$dir" -maxdepth 3 -type f \
        \( -name 'test_*.py' -o -name '*_test.py' \) -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    node)
      if [ -d "$dir/__tests__" ] || [ -d "$dir/tests" ] || [ -d "$dir/test" ] \
         || [ -d "$dir/src/__tests__" ]; then
        return 0
      fi
      matches="$(find "$dir" -maxdepth 4 -type f \
        \( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.js' -o -name '*.test.jsx' \
           -o -name '*.spec.ts' -o -name '*.spec.js' \) -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    rust)
      [ -d "$dir/tests" ] && return 0
      [ -d "$dir/src" ] && grep -rlq '#\[test\]' "$dir/src" 2>/dev/null
      ;;
    swift)
      [ -d "$dir/Tests" ]
      ;;
    go)
      matches="$(find "$dir" -maxdepth 4 -type f -name '*_test.go' -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    generic|*)
      return 1 # caller handles the 'generic' case before the not-found branch
      ;;
  esac
}

cmd_doctor() {
  local project_mode=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project) project_mode=true; shift ;;
      -h|--help)
        echo "Usage: touchstone doctor [--project]"
        echo "  (no flag)   Check touchstone installation health (CLI, tools, projects)"
        echo "  --project   Check per-project health (hooks, manifest, registry)"
        return 0
        ;;
      *) echo "ERROR: unknown argument '$1'" >&2; exit 1 ;;
    esac
  done

  if [ "$project_mode" = true ]; then
    cmd_doctor_project
    return $?
  fi

  local version
  version="$(touchstone_version_str)"
  local issues=0

  tk_header "Touchstone Doctor"

  # Version.
  if [ -n "$version" ]; then
    tk_ok "Version: v${version}"
  else
    tk_fail "Version: MISSING"
    issues=$((issues + 1))
  fi

  # Required tools.
  for tool in git gh bash; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_fail "$tool: MISSING"
      issues=$((issues + 1))
    fi
  done

  # Recommended tools.
  for tool in pre-commit gitleaks shellcheck shfmt; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_warn "$tool: not installed (run setup.sh to install)"
      issues=$((issues + 1))
    fi
  done

  # Optional tools.
  if command -v codex >/dev/null 2>&1; then
    tk_ok "codex: $(command -v codex)"
  else
    tk_dim "codex: not installed (optional — npm install -g @openai/codex)"
  fi
  if command -v but >/dev/null 2>&1; then
    tk_ok "but: $(command -v but)"
  else
    tk_dim "but: not installed (optional — GitButler CLI for stacked branches and AI-agent savepoints)"
  fi

  # Registered projects.
  tk_info "Projects"
  local projects_file="$HOME/.touchstone-projects"
  local current_id
  current_id="$(touchstone_current_id)"
  if [ -f "$projects_file" ]; then
    while IFS= read -r project_dir; do
      [ -z "$project_dir" ] && continue
      [[ "$project_dir" == \#* ]] && continue
      if [ -d "$project_dir" ]; then
        local proj_version
        proj_version="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
        local name
        name="$(basename "$project_dir")"
        if [ "$proj_version" = "$current_id" ]; then
          tk_ok "$name — up to date"
        else
          tk_warn "$name — needs sync (run: touchstone sync)"
          issues=$((issues + 1))
        fi
      else
        tk_fail "$project_dir — directory not found"
        issues=$((issues + 1))
      fi
    done < "$projects_file"
  else
    tk_dim "No projects registered yet."
  fi

  # Latest release check.
  tk_info "Latest release"
  local latest
  latest="$(curl -fsSL --max-time 5 \
    "https://api.github.com/repos/autumngarage/touchstone/releases/latest" 2>/dev/null \
    | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/')" || latest=""
  if [ -n "$latest" ]; then
    if [ "$version" = "$latest" ]; then
      tk_ok "v${latest} — you're current"
    else
      tk_warn "v${latest} available (you have v${version}). Run: brew upgrade touchstone"
      issues=$((issues + 1))
    fi
  else
    tk_dim "Couldn't check (network issue?)"
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "All good."
  else
    tk_warn "$issues issue(s) found."
  fi
  echo ""
}

cmd_list() {
  local projects_file="$HOME/.touchstone-projects"
  local current_id
  current_id="$(touchstone_current_id)"

  tk_header "Registered Projects"

  if [ ! -f "$projects_file" ] || [ ! -s "$projects_file" ]; then
    tk_dim "No projects registered. Run: touchstone new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue
    local name
    name="$(basename "$project_dir")"
    if [ -d "$project_dir" ]; then
      local proj_version
      proj_version="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
      if [ "$proj_version" = "$current_id" ]; then
        tk_ok "$name  ${DIM}$project_dir${RESET}"
      else
        tk_warn "$name  ${DIM}$project_dir${RESET}  ${YELLOW}(needs sync)${RESET}"
      fi
    else
      tk_fail "$name  ${DIM}$project_dir${RESET}  ${RED}(not found)${RESET}"
    fi
  done < "$projects_file"
  echo ""
}

cmd_unregister() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: touchstone unregister <project-path-or-name>" >&2
    exit 1
  fi

  local projects_file="$HOME/.touchstone-projects"
  if [ ! -f "$projects_file" ]; then
    tk_fail "No projects file found."
    return 1
  fi

  # Match by full path or basename.
  local matched=false
  local tmp_file
  tmp_file="$(mktemp)"
  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    if [ "$project_dir" = "$target" ] || [ "$(basename "$project_dir")" = "$target" ]; then
      tk_ok "Unregistered: $project_dir"
      matched=true
    else
      echo "$project_dir" >> "$tmp_file"
    fi
  done < "$projects_file"
  mv "$tmp_file" "$projects_file"

  if [ "$matched" = false ]; then
    tk_fail "No project matching '$target' found in registry."
    return 1
  fi
}

cmd_diff() {
  tk_header "Template Diff"
  tk_dim "Comparing project files against latest touchstone templates"
  echo ""

  local has_diff=false
  local pairs=(
    "CLAUDE.md:templates/CLAUDE.md"
    "AGENTS.md:templates/AGENTS.md"
    ".pre-commit-config.yaml:templates/pre-commit-config.yaml"
    ".codex-review.toml:hooks/codex-review.config.example.toml"
  )

  for pair in "${pairs[@]}"; do
    local project_file="${pair%%:*}"
    local template_file="${pair##*:}"
    local template_path="$TOUCHSTONE_ROOT/$template_file"

    if [ ! -f "$project_file" ]; then
      tk_dim "$project_file — not found (skipped)"
      continue
    fi
    if [ ! -f "$template_path" ]; then
      continue
    fi

    if diff -q "$project_file" "$template_path" >/dev/null 2>&1; then
      tk_ok "$project_file — matches template"
    else
      has_diff=true
      echo "${BOLD}--- $project_file (project)${RESET}"
      echo "${BOLD}+++ $template_file (touchstone template)${RESET}"
      diff -u "$project_file" "$template_path" 2>/dev/null | tail -n +3 || true
      echo ""
    fi
  done

  if [ "$has_diff" = false ]; then
    tk_ok "All project-owned files match templates."
  fi
  echo ""
}

cmd_adr() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      tk_header "Architecture Decision Records"
      if [ -d "docs/adr" ] && ls docs/adr/*.md >/dev/null 2>&1; then
        for f in docs/adr/[0-9]*.md; do
          local num title
          num="$(basename "$f" .md | grep -o '^[0-9]*')"
          title="$(head -1 "$f" | sed 's/^#* *//' | sed "s/^ADR-$num: //")"
          printf "  ${BOLD}ADR-%s${RESET}: %s\n" "$num" "$title"
        done
      else
        tk_dim "No ADRs found. Create one with: touchstone adr \"Title of decision\""
      fi
      echo ""
      ;;
    "")
      echo "Usage:" >&2
      echo "  touchstone adr \"Title of decision\"    Create a new ADR" >&2
      echo "  touchstone adr list                    List all ADRs" >&2
      exit 1
      ;;
    *)
      # Create a new ADR. The subcmd and remaining args form the title.
      local title="$subcmd $*"
      title="$(echo "$title" | sed 's/[[:space:]]*$//')"

      mkdir -p docs/adr

      # Find next number.
      local last_num=0
      if ls docs/adr/[0-9]*.md >/dev/null 2>&1; then
        last_num="$(ls docs/adr/[0-9]*.md | sed 's/.*\///' | grep -o '^[0-9]*' | sort -n | tail -1)"
      fi
      local next_num=$((10#$last_num + 1))
      local padded
      padded="$(printf "%04d" "$next_num")"

      local slug
      slug="$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')"
      local filename="docs/adr/${padded}-${slug}.md"

      local today
      today="$(date +%Y-%m-%d)"

      # Copy template and fill in.
      cp "$TOUCHSTONE_ROOT/templates/adr/0000-template.md" "$filename"
      sed -i '' "s/NNNN/$padded/g" "$filename"
      escaped_title="$(escape_sed_replacement "$title")"
      sed -i '' "s/TITLE/$escaped_title/g" "$filename"
      sed -i '' "s/DATE/$today/g" "$filename"

      tk_ok "Created: $filename"
      ;;
  esac
}

cmd_skills() {
  local subcmd="${1:-list}"

  case "$subcmd" in
    list)
      tk_header "Claude Code Skills"

      local found=false

      # Project-level skills.
      if [ -d ".claude/skills" ]; then
        for skill_dir in .claude/skills/*/; do
          [ -d "$skill_dir" ] || continue
          found=true
          local name
          name="$(basename "$skill_dir")"
          local status=""
          if [ -L "$skill_dir" ]; then
            local target
            target="$(readlink "$skill_dir")"
            status="${DIM}symlink → $target${RESET}"
          else
            status="${DIM}local${RESET}"
          fi
          if [ -f "${skill_dir}SKILL.md" ]; then
            printf "  ${GREEN}✓${RESET} ${BOLD}%-25s${RESET} project   %b\n" "$name" "$status"
          else
            printf "  ${RED}✗${RESET} ${BOLD}%-25s${RESET} project   %b ${RED}(missing SKILL.md)${RESET}\n" "$name" "$status"
          fi
        done
      fi

      # User-level skills.
      if [ -d "$HOME/.claude/skills" ]; then
        for skill_dir in "$HOME/.claude/skills"/*/; do
          [ -d "$skill_dir" ] || continue
          found=true
          local name
          name="$(basename "$skill_dir")"
          local status=""
          if [ -L "$skill_dir" ]; then
            local target
            target="$(readlink "$skill_dir")"
            status="${DIM}symlink → $target${RESET}"
          else
            status="${DIM}standalone (no symlink)${RESET}"
          fi
          if [ -f "${skill_dir}SKILL.md" ]; then
            printf "  ${GREEN}✓${RESET} ${BOLD}%-25s${RESET} user      %b\n" "$name" "$status"
          else
            printf "  ${RED}✗${RESET} ${BOLD}%-25s${RESET} user      %b ${RED}(missing SKILL.md)${RESET}\n" "$name" "$status"
          fi
        done
      fi

      if [ "$found" = false ]; then
        tk_dim "No skills found."
        tk_dim "Project skills:  .claude/skills/<name>/SKILL.md"
        tk_dim "User skills:     ~/.claude/skills/<name>/SKILL.md"
      fi
      echo ""
      ;;

    check)
      tk_header "Skill Validation"

      local issues=0
      local checked=0
      local dirs=()

      if [ -d ".claude/skills" ]; then
        for d in .claude/skills/*/; do [ -d "$d" ] && dirs+=("$d"); done
      fi
      if [ -d "$HOME/.claude/skills" ]; then
        for d in "$HOME/.claude/skills"/*/; do [ -d "$d" ] && dirs+=("$d"); done
      fi

      if [ "${#dirs[@]}" -eq 0 ]; then
        tk_dim "No skills found."
        echo ""
        return
      fi

      for skill_dir in "${dirs[@]}"; do
        checked=$((checked + 1))
        local name
        name="$(basename "$skill_dir")"
        local skill_file="${skill_dir}SKILL.md"

        if [ ! -f "$skill_file" ]; then
          tk_fail "$name — missing SKILL.md"
          issues=$((issues + 1))
          continue
        fi

        # Check frontmatter exists.
        if ! head -1 "$skill_file" | grep -q '^---$'; then
          tk_fail "$name — SKILL.md missing frontmatter (no leading ---)"
          issues=$((issues + 1))
          continue
        fi

        tk_ok "$name — valid"
      done

      echo ""
      if [ "$issues" -eq 0 ]; then
        tk_ok "All $checked skills valid."
      else
        tk_warn "$issues/$checked skills have issues."
      fi
      echo ""
      ;;

    *)
      echo "Usage:" >&2
      echo "  touchstone skills           List all skills" >&2
      echo "  touchstone skills check     Validate skill files" >&2
      exit 1
      ;;
  esac
}

cmd_release() {
  source "$TOUCHSTONE_ROOT/lib/release.sh"

  local bump_type="minor"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --major) bump_type="major"; shift ;;
      --minor) bump_type="minor"; shift ;;
      --patch) bump_type="patch"; shift ;;
      *) echo "Usage: touchstone release [--major|--minor|--patch]" >&2; exit 1 ;;
    esac
  done

  touchstone_release "$bump_type"
}

cmd_changelog() {
  local count="${1:-10}"
  tk_header "Recent Releases"

  if ! command -v gh >/dev/null 2>&1; then
    tk_fail "gh CLI not installed. Run: brew install gh"
    return 1
  fi

  gh release list --repo autumngarage/touchstone --limit "$count" 2>/dev/null || {
    tk_fail "Couldn't fetch releases (network issue or auth problem)."
    tk_dim "Fallback — recent commits:"
    git -C "$TOUCHSTONE_ROOT" log --oneline -"$count" 2>/dev/null || true
  }
  echo ""
}

cmd_help() {
  tk_header "touchstone — shared engineering starter kit"
  echo "  ${BOLD}Project commands:${RESET}"
  printf "    ${BOLD}touchstone init${RESET} [--no-setup]      Add touchstone to the current project\n"
  printf "    ${BOLD}touchstone init${RESET} --review-routing small-local  Use local review for small diffs\n"
  printf "    ${BOLD}touchstone init${RESET} --gitbutler       Add optional GitButler workflow setup\n"
  printf "    ${BOLD}touchstone new${RESET} <dir>              Bootstrap a new project from scratch\n"
  printf "    ${BOLD}touchstone detect${RESET}                 Show detected project profile\n"
  printf "    ${BOLD}touchstone run${RESET} <task>             Run lint, typecheck, build, test, or validate\n"
  printf "    ${BOLD}touchstone update${RESET}                 Create a branch + commit for touchstone updates\n"
  printf "    ${BOLD}touchstone update${RESET} --dry-run       Preview what would change\n"
  printf "    ${BOLD}touchstone update${RESET} --check         Report whether this project needs update\n"
  printf "    ${BOLD}touchstone migrate-from-toolkit${RESET}   One-shot rename of legacy .toolkit-* files (pre-1.0.0 projects)\n"
  printf "    ${BOLD}touchstone sync${RESET}                   Update all registered projects\n"
  printf "    ${BOLD}touchstone sync${RESET} --check           Report which projects need sync\n"
  printf "    ${BOLD}touchstone sync${RESET} --pull-first      Pull latest touchstone first\n"
  printf "    ${BOLD}touchstone diff${RESET}                   Compare project files vs templates\n"
  printf "    ${BOLD}touchstone adr${RESET} \"Title\"            Create an Architecture Decision Record\n"
  printf "    ${BOLD}touchstone adr${RESET} list               List all ADRs\n"
  echo ""
  echo "  ${BOLD}Registry commands:${RESET}"
  printf "    ${BOLD}touchstone list${RESET}                   Show registered projects\n"
  printf "    ${BOLD}touchstone unregister${RESET} <name>      Remove a project from registry\n"
  printf "    ${BOLD}touchstone status${RESET}                 Dashboard — all projects at a glance\n"
  echo ""
  echo "  ${BOLD}Touchstone commands:${RESET}"
  printf "    ${BOLD}touchstone doctor${RESET}                 Check installation health\n"
  printf "    ${BOLD}touchstone doctor${RESET} --project       Check per-project health (hooks, manifest, registry)\n"
  printf "    ${BOLD}touchstone version${RESET}                Show installed version\n"
  printf "    ${BOLD}touchstone changelog${RESET} [N]          Show last N releases (default 10)\n"
  printf "    ${BOLD}touchstone skills${RESET}                 List Claude Code skills\n"
  printf "    ${BOLD}touchstone skills${RESET} check           Validate skill files\n"
  printf "    ${BOLD}touchstone release${RESET} [--patch]      Cut a new touchstone release\n"
  printf "    ${BOLD}touchstone help${RESET}                   Show this help\n"
  echo ""
  printf "  Install: ${DIM}brew tap autumngarage/touchstone && brew install touchstone${RESET}\n"
  echo ""
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  new)          cmd_new "$@" ;;
  init)         cmd_init "$@" ;;
  run)          cmd_run "$@" ;;
  detect)       cmd_detect ;;
  update)       cmd_update "$@" ;;
  migrate-from-toolkit) cmd_migrate_from_toolkit "$@" ;;
  sync)         cmd_sync "$@" ;;
  status)       cmd_status ;;
  list|ls)      cmd_list ;;
  unregister)   cmd_unregister "$@" ;;
  diff)         cmd_diff ;;
  adr)          cmd_adr "$@" ;;
  skills)       cmd_skills "$@" ;;
  changelog)    cmd_changelog "$@" ;;
  release)      cmd_release "$@" ;;
  version)      cmd_version ;;
  doctor)       cmd_doctor "$@" ;;
  help|-h|--help) cmd_help ;;
  *)
    printf "${RED}Unknown command: $COMMAND${RESET}\n" >&2
    echo "Run 'touchstone help' for usage." >&2
    exit 1
    ;;
esac
