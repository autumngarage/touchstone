#!/usr/bin/env bash
#
# touchstone — CLI for the shared engineering starter kit.
#
# Usage:
#   touchstone new <project-dir>          Create a new project with touchstone files
#   touchstone init [--no-setup] [--type node|python|swift|rust|go|generic|auto] [--reviewer conductor|none (or legacy: codex|claude|gemini|local|auto)]
#                                      Add touchstone to the current project
#   touchstone run <task>                  Run profile task: lint, test, build, typecheck, validate
#   touchstone update                     Update current project to latest touchstone
#   touchstone update --in-place          Update on the current branch
#   touchstone update --dry-run           Show what would change without applying
#   touchstone update --check             Report whether current project needs update
#   touchstone update --ship              Push, open PR, review, and auto-merge
#   touchstone sync                       Update all registered projects
#   touchstone sync --pull-first          Pull latest touchstone, then sync all projects
#   touchstone status                     Show status of the current project
#   touchstone status --all               Show version distribution across registered projects
#   touchstone version                    Show installed version
#   touchstone doctor                     Check health of touchstone installation
#   touchstone help                       Show this help
#
# Install:
#   brew tap autumngarage/touchstone
#   brew install touchstone
#
set -euo pipefail

# Resolve TOUCHSTONE_ROOT — works whether installed via brew symlink or clone.
SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [ -h "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
TOUCHSTONE_ROOT="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"
export TOUCHSTONE_ROOT

# Source shared libraries.
source "$TOUCHSTONE_ROOT/lib/auto-update.sh"
source "$TOUCHSTONE_ROOT/lib/colors.sh"
source "$TOUCHSTONE_ROOT/lib/ui.sh"
source "$TOUCHSTONE_ROOT/lib/claude-md-principles-ref.sh"
source "$TOUCHSTONE_ROOT/lib/status.sh"

# Auto-update check (throttled, non-blocking on failure).
touchstone_auto_update || true

# Helper: get touchstone version string.
touchstone_version_str() {
  cat "$TOUCHSTONE_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'
}

# Helper: get touchstone identifier for comparison (git SHA or version).
touchstone_current_id() {
  if [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    git -C "$TOUCHSTONE_ROOT" rev-parse HEAD
  else
    touchstone_version_str
  fi
}

touchstone_current_id_short() {
  if [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    git -C "$TOUCHSTONE_ROOT" rev-parse --short HEAD
  else
    touchstone_version_str
  fi
}

escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[\\/&]/\\&/g'
}

# --------------------------------------------------------------------------
# Subcommands
# --------------------------------------------------------------------------

cmd_new() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: touchstone new <project-dir> [--no-register] [--type node|python|swift|rust|go|generic|auto] [--unsafe-paths path1,path2] [--reviewer conductor|none (or legacy: codex|claude|gemini|local|auto)] [--review-routing all-hosted|all-local|small-local] [--gitbutler|--no-gitbutler] [--ci github|--no-ci] [--scaffold-tests]" >&2
    exit 1
  fi
  case "${1:-}" in
    -h|--help)
      echo "Usage: touchstone new <project-dir> [--no-register] [--type node|python|swift|rust|go|generic|auto] [--unsafe-paths path1,path2] [--reviewer conductor|none (or legacy: codex|claude|gemini|local|auto)] [--review-routing all-hosted|all-local|small-local] [--small-review-lines N] [--gitbutler|--no-gitbutler] [--gitbutler-mcp|--no-gitbutler-mcp] [--ci github|--no-ci] [--scaffold-tests]"
      return 0
      ;;
  esac
  exec bash "$TOUCHSTONE_ROOT/bootstrap/new-project.sh" "$@"
}

cmd_init() {
  # Init the current directory — bootstrap + setup in one command.
  local run_setup=true
  local setup_existed=false
  local ship_upgrade=true
  local claude_principles_mode="prompt"
  local args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-setup)
        run_setup=false
        shift
        ;;
      --ship)
        ship_upgrade=true
        shift
        ;;
      --no-ship)
        ship_upgrade=false
        shift
        ;;
      -h|--help)
        echo "Usage: touchstone init [--no-setup] [--type node|python|swift|rust|go|generic|auto] [--no-register] [--unsafe-paths path1,path2] [--reviewer conductor|none (or legacy: codex|claude|gemini|local|auto)] [--review-routing all-hosted|all-local|small-local] [--small-review-lines N] [--gitbutler|--no-gitbutler] [--gitbutler-mcp|--no-gitbutler-mcp] [--ci github|--no-ci] [--scaffold-tests] [--claude-principles yes|no|prompt] [--no-claude-principles]"
        return 0
        ;;
      --type)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --type requires a value (node, python, swift, rust, go, generic, auto)" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --no-register)
        args+=("$1")
        shift
        ;;
      --unsafe-paths)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --unsafe-paths requires a comma-separated value" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --reviewer|--local-review-command|--review-routing|--small-review-lines|--git-workflow)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: $1 requires a value" >&2
          exit 1
        fi
        args+=("$1" "$2")
        shift 2
        ;;
      --ci)
        # --ci may stand alone (defaults to github) or take a value.
        if [ "$#" -ge 2 ] && [[ "$2" != --* ]]; then
          args+=("$1" "$2")
          shift 2
        else
          args+=("$1")
          shift
        fi
        ;;
      --no-ai-review|--no-review|--review-assist|--no-review-assist|--review-autofix|--no-review-autofix|--gitbutler|--no-gitbutler|--gitbutler-mcp|--no-gitbutler-mcp|--no-ci|--scaffold-tests)
        args+=("$1")
        shift
        ;;
      --claude-principles)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --claude-principles requires a value (yes, no, or prompt)" >&2
          exit 1
        fi
        case "$2" in
          yes|no|prompt) claude_principles_mode="$2" ;;
          *)
            echo "ERROR: --claude-principles must be 'yes', 'no', or 'prompt' (got '$2')" >&2
            exit 1
            ;;
        esac
        shift 2
        ;;
      --no-claude-principles)
        claude_principles_mode="no"
        shift
        ;;
      *)
        echo "ERROR: unknown argument '$1'" >&2
        echo "Usage: touchstone init [--no-setup] [--type node|python|swift|rust|go|generic|auto] [--no-register] [--unsafe-paths path1,path2] [--reviewer conductor|none (or legacy: codex|claude|gemini|local|auto)] [--review-routing all-hosted|all-local|small-local] [--gitbutler|--no-gitbutler] [--ci github|--no-ci] [--scaffold-tests] [--claude-principles yes|no|prompt] [--no-claude-principles]" >&2
        exit 1
        ;;
    esac
  done

  if [ -e "$(pwd)/setup.sh" ]; then
    setup_existed=true
  fi

  # State detection: fresh | current | outdated | legacy-toolkit. Determines
  # whether init bootstraps or reconciles files in place.
  local project_dir installed_id current_id init_state="fresh"
  project_dir="$(pwd)"

  if [ -f "$project_dir/.toolkit-version" ] && [ -f "$project_dir/.touchstone-version" ]; then
    tk_fail "Migration conflict: both .toolkit-version and .touchstone-version are present in $project_dir"
    tk_dim "  Fix: rm .toolkit-version   (touchstone has already been installed here)"
    return 1
  elif [ -f "$project_dir/.toolkit-version" ]; then
    init_state="legacy-toolkit"
  elif [ -f "$project_dir/.touchstone-version" ]; then
    installed_id="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "")"
    current_id="$(touchstone_current_id)"
    if [ "$installed_id" = "$current_id" ]; then
      init_state="current"
    else
      init_state="outdated"
    fi
  fi

  case "$init_state" in
    legacy-toolkit)
      tk_fail "Legacy .toolkit-version found in $project_dir"
      tk_dim "Run: touchstone migrate-from-toolkit"
      tk_dim "Then re-run: touchstone init"
      return 1
      ;;
    outdated)
      tk_header "Touchstone init — reconciling"
      tk_dim "  installed: ${installed_id:0:12}"
      tk_dim "  current:   ${current_id:0:12}"
      tk_info "This repo is on an older Touchstone; init will reconcile files in place."
      if [ "$ship_upgrade" = true ]; then
        tk_dim "For a reviewable branch + PR instead, run: touchstone update --ship"
      else
        tk_dim "For a reviewable branch + commit instead, run: touchstone update"
      fi
      echo ""
      # `init` is a repair/reconcile command, so it must not silently switch
      # branches or create orphaned PRs when the project is stale. The
      # reviewable update flow remains available as `touchstone update`.
      ;;
  esac

  # Fresh init: greet with the branded hero so setup feels like setup.
  tk_hero "setting up this project"

  bash "$TOUCHSTONE_ROOT/bootstrap/new-project.sh" "$project_dir" ${args[@]+"${args[@]}"}

  # Connect CLAUDE.md (or record that we already are). new-project.sh's
  # template copy plants the imports on a fresh init, so this normally
  # records `connected` without prompting. The interesting case is `current`
  # state on a project whose user wrote their own CLAUDE.md without imports
  # — then we prompt.
  ensure_claude_principles_ref "$project_dir" "$claude_principles_mode"

  # Only fresh init runs setup.sh automatically. Reconciling an existing repo
  # must not re-trigger machine-wide dev-tool installs or interactive prompts
  # just because the user happened to delete setup.sh before re-running init.
  if [ "$init_state" = "fresh" ] && [ "$run_setup" = true ] && [ -f "$project_dir/setup.sh" ]; then
    if [ "$setup_existed" = true ]; then
      tk_warn "setup.sh already existed, so touchstone left it in place and did not run it."
      tk_dim "Run manually if desired: bash setup.sh"
      return 0
    fi
    echo ""
    bash "$project_dir/setup.sh"
  fi
}

cmd_update() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/update-project.sh" "$@"
}

cmd_migrate_from_toolkit() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/migrate-from-toolkit.sh" "$@"
}

cmd_migrate_review_config() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/migrate-review-config.sh" "$@"
}

cmd_review() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/review.sh" "$@"
}

cmd_sync() {
  exec bash "$TOUCHSTONE_ROOT/bootstrap/sync-all.sh" "$@"
}

cmd_run() {
  exec bash "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" "$@"
}

cmd_detect() {
  exec bash "$TOUCHSTONE_ROOT/scripts/touchstone-run.sh" detect
}

cmd_version() {
  local version
  version="$(touchstone_version_str)"
  tk_header "touchstone v${version:-unknown}"

  if command -v brew >/dev/null 2>&1 && brew list touchstone &>/dev/null; then
    tk_dim "installed via: brew"
    tk_dim "prefix: $(brew --prefix touchstone 2>/dev/null || echo unknown)"
  elif [ -d "$TOUCHSTONE_ROOT/.git" ]; then
    tk_dim "installed via: git clone"
    tk_dim "path: $TOUCHSTONE_ROOT"
    tk_dim "commit: $(git -C "$TOUCHSTONE_ROOT" rev-parse --short HEAD 2>/dev/null)"
  fi

  local projects_file="$HOME/.touchstone-projects"
  if [ -f "$projects_file" ]; then
    local count
    count="$(grep -c '[^[:space:]]' "$projects_file" 2>/dev/null || echo 0)"
    tk_dim "projects: $count registered"
  fi
}

cmd_status() {
  # Two views, one entrypoint:
  #   touchstone status         -> single-project block for $(pwd)
  #   touchstone status --all   -> registry walk with the version-distribution table
  #
  # This intentionally narrows the old `touchstone status` (which always
  # walked the registry). The registry view moves to `--all` so the bare
  # command is useful inside any one project — the more common ask. The
  # old behavior remains reachable via `--all`; `touchstone list` is
  # the registry-only listing without the version-distribution math.
  local mode="project"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --all|-a) mode="all"; shift ;;
      -h|--help)
        echo "Usage: touchstone status [--all]"
        echo "  (no flag)  Show status for the current working directory"
        echo "  --all      Show version distribution across registered projects"
        return 0
        ;;
      *) echo "ERROR: unknown argument '$1'" >&2; exit 1 ;;
    esac
  done

  if [ "$mode" = "all" ]; then
    status_print_all
    return $?
  fi

  status_print_project "$(pwd)"
}

cmd_doctor_project() {
  local project_dir issues=0
  project_dir="$(pwd)"

  tk_header "Touchstone Project Doctor — $(basename "$project_dir")"

  # 1. Is this a touchstone-managed project? Reject migration-conflict state first —
  # a project with both files is mid-migration and must not be reported healthy.
  if [ -f "$project_dir/.toolkit-version" ] && [ -f "$project_dir/.touchstone-version" ]; then
    tk_fail "Migration conflict: both .toolkit-version and .touchstone-version present"
    tk_dim "  Fix: rm .toolkit-version   (touchstone has already been installed)"
    echo ""
    return 1
  fi
  if [ ! -f "$project_dir/.touchstone-version" ]; then
    if [ -f "$project_dir/.toolkit-version" ]; then
      tk_fail "Legacy .toolkit-version found"
      tk_dim "  Fix: touchstone migrate-from-toolkit"
      echo ""
      return 1
    fi
    tk_fail "Not a touchstone project (no .touchstone-version)"
    tk_dim "  Fix: touchstone init"
    echo ""
    return 1
  fi

  local installed_id current_id
  installed_id="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "")"
  current_id="$(touchstone_current_id)"
  if [ "$installed_id" = "$current_id" ]; then
    tk_ok "touchstone version matches: ${installed_id:0:12}"
  else
    tk_warn "touchstone out of date (installed ${installed_id:0:12}, current ${current_id:0:12})"
    tk_dim "  Fix: touchstone update"
    issues=$((issues + 1))
  fi

  # 2. Git hooks installed? This is the footgun that silently ungates a repo.
  # Verify three separate failure modes because Git silently no-ops on any of them:
  #   - file absent → hook never runs
  #   - file present but not executable → Git skips it (same effect as absent)
  #   - file executable but not the pre-commit-framework shim → another hook
  #     framework replaced it; pushes proceed without Codex review / validate.
  if [ ! -f "$project_dir/.pre-commit-config.yaml" ]; then
    tk_warn ".pre-commit-config.yaml is missing"
    tk_dim "  Fix: touchstone init  (reconciles missing templates)"
    issues=$((issues + 1))
  else
    if [ -f "$project_dir/.git/hooks/pre-commit" ] && [ -f "$project_dir/.git/hooks/pre-push" ]; then
      if [ ! -x "$project_dir/.git/hooks/pre-commit" ] || [ ! -x "$project_dir/.git/hooks/pre-push" ]; then
        tk_fail "git hooks exist but are not executable — Git will skip them, repo is ungated"
        tk_dim "  Fix: chmod +x $project_dir/.git/hooks/pre-commit $project_dir/.git/hooks/pre-push"
        issues=$((issues + 1))
      elif grep -q 'pre-commit\.com' "$project_dir/.git/hooks/pre-push" 2>/dev/null \
           && grep -q 'pre-commit\.com' "$project_dir/.git/hooks/pre-commit" 2>/dev/null; then
        tk_ok "git hooks installed (.git/hooks/pre-commit, .git/hooks/pre-push)"
      else
        tk_warn "git hook files exist but aren't the pre-commit-framework shim"
        tk_dim "  Another hook framework may have replaced them."
        tk_dim "  Fix: pre-commit install --hook-type pre-commit --hook-type pre-push"
        issues=$((issues + 1))
      fi
    else
      tk_fail "git hooks NOT installed — repo is ungated"
      if command -v pre-commit >/dev/null 2>&1; then
        tk_dim "  Fix: touchstone init   (idempotent — reinstalls missing hooks)"
      else
        tk_dim "  Fix: brew install pre-commit && touchstone init"
      fi
      issues=$((issues + 1))
    fi
  fi

  # 3. Manifest files present?
  if [ -f "$project_dir/.touchstone-manifest" ]; then
    local missing=0 line
    while IFS= read -r line || [ -n "$line" ]; do
      line="${line#"${line%%[![:space:]]*}"}"
      line="${line%"${line##*[![:space:]]}"}"
      [ -z "$line" ] && continue
      case "$line" in \#*) continue ;; esac
      if [ ! -e "$project_dir/$line" ]; then
        tk_fail "manifest file missing: $line"
        missing=$((missing + 1))
      fi
    done < "$project_dir/.touchstone-manifest"
    if [ "$missing" -eq 0 ]; then
      tk_ok "manifest files all present"
    else
      tk_dim "  Fix: touchstone init  (reconciles missing files)"
      issues=$((issues + missing))
    fi
  else
    tk_warn ".touchstone-manifest missing"
    tk_dim "  Fix: touchstone init"
    issues=$((issues + 1))
  fi

  # 4. Scripts executable?
  if [ -d "$project_dir/scripts" ]; then
    local not_executable=0 script
    for script in "$project_dir/scripts/"*.sh; do
      [ -f "$script" ] || continue
      if [ ! -x "$script" ]; then
        tk_fail "not executable: scripts/$(basename "$script")"
        not_executable=$((not_executable + 1))
      fi
    done
    if [ "$not_executable" -eq 0 ]; then
      tk_ok "scripts are executable"
    else
      tk_dim "  Fix: chmod +x $project_dir/scripts/*.sh"
      issues=$((issues + not_executable))
    fi
  fi

  # 5. Registered in ~/.touchstone-projects?  Informational — 'touchstone sync'
  # and 'touchstone list' depend on it, but the repo is still functionally gated.
  local projects_file="$HOME/.touchstone-projects"
  if [ -f "$projects_file" ] && grep -qxF "$project_dir" "$projects_file" 2>/dev/null; then
    tk_ok "registered in ~/.touchstone-projects"
  else
    tk_dim "not in ~/.touchstone-projects (touchstone sync won't update this project)"
    tk_dim "  Fix: echo \"$project_dir\" >> $projects_file"
  fi

  # 6. Optional — Codex review config present?
  if [ -f "$project_dir/.codex-review.toml" ]; then
    tk_ok ".codex-review.toml present"
  else
    tk_dim ".codex-review.toml not found (optional — configures AI review)"
  fi

  # 7. Profile-aware test-surface and tooling gap checks.
  # touchstone-run.sh validate silently skips when test files / linters are
  # absent (correct runtime UX). doctor is where those gaps become visible.
  #
  # Read profile + targets from .touchstone-config directly rather than from
  # `touchstone-run.sh detect`. detect() auto-populates targets by walking
  # apps/packages/services when config has none, but the runner's
  # run_targets_action bails unless config-loaded TARGETS is non-empty — so
  # a doctor that trusts detect output would check per-target profiles the
  # runner never actually dispatches to.
  local profile="" targets=""
  # touchstone-run.sh:load_config treats project_type and profile as the same
  # config slot with last-write-wins semantics — mirror that here so a config
  # with both keys selects the same profile doctor and validate use.
  profile="$(_touchstone_config_get "$project_dir" "project_type profile")"
  targets="$(_touchstone_config_get "$project_dir" "targets")"

  # Match the runner's profile resolution precisely:
  #   empty/auto -> manifest detection
  #   literal "generic" but manifest detects a typed profile -> upgrade to detected
  #   else -> use as-declared (to be normalized below)
  if [ -z "$profile" ] || [ "$profile" = "auto" ]; then
    profile="$(_touchstone_detect_profile_dir "$project_dir")"
  elif [ "$profile" = "generic" ]; then
    local detected
    detected="$(_touchstone_detect_profile_dir "$project_dir")"
    [ "$detected" != "generic" ] && profile="$detected"
  fi
  profile="$(_touchstone_normalize_profile "$profile")"

  # Any profile value outside the dispatcher's accepted set is an error the
  # runner will surface at pre-push — flag it here so doctor doesn't report
  # green on a config the runner will reject.
  if ! _touchstone_profile_is_valid "$profile"; then
    tk_warn "unknown project_type '$profile' in .touchstone-config — touchstone-run.sh will reject it"
    tk_dim "  Valid profiles: node, python, rust, swift, go, generic, auto"
    issues=$((issues + 1))
  fi

  # Root-level overrides short-circuit the dispatcher entirely (configured_command_for_action
  # in touchstone-run.sh), so neither per-root nor per-target profile defaults run.
  local tests_overridden=false lint_overridden=false
  if _touchstone_config_has_override "$project_dir" test_command \
     || _touchstone_config_has_override "$project_dir" validate_command; then
    tests_overridden=true
  fi
  if _touchstone_config_has_override "$project_dir" lint_command \
     || _touchstone_config_has_override "$project_dir" validate_command; then
    lint_overridden=true
  fi

  # 7a. Test presence — informational nudge, not a blocking issue.
  if [ "$tests_overridden" = true ]; then
    tk_dim "tests: overridden via .touchstone-config"
  elif [ -n "$targets" ]; then
    _touchstone_doctor_foreach_target "$project_dir" "$targets" _touchstone_doctor_check_tests
  else
    _touchstone_doctor_check_tests "$project_dir" "$profile" ""
  fi

  # 7b. Profile lint tool availability — a real gap when missing because the
  # runtime graceful-skip means lint issues merge uncaught.
  if [ "$lint_overridden" = true ]; then
    tk_dim "lint: overridden via .touchstone-config"
  elif [ -n "$targets" ]; then
    _touchstone_doctor_foreach_target "$project_dir" "$targets" _touchstone_doctor_check_lint
  else
    _touchstone_doctor_check_lint "$project_dir" "$profile" ""
  fi

  # 8. Autumn Garage siblings — orientation-only, never blocking.
  # Autumn Garage Doctrine 0001 forbids code imports across the trio, so this
  # check is file-contract only: shell out to the sibling CLI for a version
  # string and look at the project-local marker directory. Absence is normal.
  tk_info "Autumn Garage siblings"
  _touchstone_doctor_check_sibling "$project_dir" cortex   ".cortex"            "brew install autumngarage/cortex/cortex"
  _touchstone_doctor_check_sibling "$project_dir" sentinel ".sentinel"          "brew install autumngarage/sentinel/sentinel"

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "Project is fully armed."
    echo ""
    return 0
  fi
  tk_warn "$issues issue(s) found. See fixes above, or run: touchstone init"
  echo ""
  return 1
}

# Report presence + version of a sibling CLI in the Autumn Garage trio.
# File-contract only — no code imports, no reading sibling config beyond a
# presence check on the marker directory. `command -v` for the CLI; a 3s
# timeout on the version subcommand so a hung sibling can't stall doctor.
# Absence is never an issue (does not touch $issues in the caller); a CLI
# that's missing while the marker directory is present is an unusual state
# worth flagging (tk_warn), still non-blocking.
#
# Always returns 0 so `set -e` in the caller doesn't abort on a missing CLI.
_touchstone_doctor_check_sibling() {
  local project_dir="$1" name="$2" marker_rel="$3" install_hint="$4"
  local marker_state="absent" marker_note
  if [ -d "$project_dir/$marker_rel" ]; then
    marker_state="present"
  fi
  marker_note="${marker_rel}/ ${marker_state}"

  if command -v "$name" >/dev/null 2>&1; then
    local version_raw="" version=""
    # 3-second wall-clock cap per probe so a hung sibling can't stall doctor.
    # `perl -e alarm` is portable across macOS + Linux without needing GNU timeout.
    # Try `<cli> version` first (cortex convention, Touchstone convention);
    # fall back to `<cli> --version` (Click / argparse default, Sentinel).
    # Both stdout and stderr are captured because Click prints --version to stdout
    # but unknown-subcommand errors to stderr — combining them keeps the regex
    # hunt below from accidentally parsing "Error: No such command 'version'".
    for probe in "version" "--version"; do
      version_raw="$(perl -e 'alarm 3; exec @ARGV' "$name" "$probe" 2>/dev/null || true)"
      # A semver-ish token in the output means we found a real version reply;
      # otherwise try the next probe.
      if printf '%s' "$version_raw" | grep -Eq '[0-9]+\.[0-9]+(\.[0-9]+)?'; then
        break
      fi
      version_raw=""
    done
    # Extract the first semver-ish token so the output shape is stable even if
    # the sibling's version output wraps the number with other text.
    version="$(printf '%s' "$version_raw" | awk '
      { for (i=1;i<=NF;i++) if (match($i, /[0-9]+\.[0-9]+(\.[0-9]+)?/)) {
          print substr($i, RSTART, RLENGTH); exit
        }
      }
    ')"
    [ -z "$version" ] && version="?"
    tk_ok "$name $version (installed) — $marker_note"
    return 0
  fi

  if [ "$marker_state" = "present" ]; then
    tk_warn "$name CLI missing but $marker_rel/ present — install: $install_hint"
    return 0
  fi

  tk_dim "$name not installed"
  return 0
}

# Report whether .touchstone-config assigns a non-empty value to the given key.
# Used to suppress profile-default doctor checks when a project has overridden
# the runner's behavior — otherwise doctor false-positives on correct configs.
_touchstone_config_has_override() {
  local dir="$1" key="$2"
  [ -f "$dir/.touchstone-config" ] || return 1
  # Match "key = value" where value has at least one non-space character.
  # Skips commented-out lines ("# key=...") and empty assignments ("key=").
  grep -Eq "^[[:space:]]*${key}[[:space:]]*=[[:space:]]*[^[:space:]#]" "$dir/.touchstone-config"
}

# Read a raw value from .touchstone-config. Empty string when absent.
# Trims whitespace around both key and value so "key = value" and "key=value"
# both match, consistent with scripts/touchstone-run.sh:load_config.
# Matches scripts/touchstone-run.sh:load_config semantics: when the same key
# appears multiple times, the last non-empty assignment wins (for project_type
# the runner treats project_type and profile as aliases — pass a space-
# separated list of keys in "$2" to preserve that behavior).
_touchstone_config_get() {
  local dir="$1" keys="$2" line value candidate k
  local result=""
  [ -f "$dir/.touchstone-config" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line#"${line%%[![:space:]]*}"}"
    case "$line" in \#*|"") continue ;; esac
    case "$line" in *=*) ;; *) continue ;; esac
    candidate="${line%%=*}"
    candidate="${candidate#"${candidate%%[![:space:]]*}"}"
    candidate="${candidate%"${candidate##*[![:space:]]}"}"
    for k in $keys; do
      if [ "$candidate" = "$k" ]; then
        value="${line#*=}"
        value="${value#"${value%%[![:space:]]*}"}"
        value="${value%"${value##*[![:space:]]}"}"
        result="$value"
        break
      fi
    done
  done < "$dir/.touchstone-config"
  printf '%s' "$result"
}

# Validate a profile name against the set scripts/touchstone-run.sh actually
# dispatches on. run_profile_action treats anything outside this set as an
# "unknown project_type" error, so doctor must flag the same.
_touchstone_profile_is_valid() {
  case "$1" in
    node|python|rust|swift|go|generic) return 0 ;;
    *) return 1 ;;
  esac
}

# Auto-detect a project profile from manifest files. Must stay in lock-step
# with scripts/touchstone-run.sh:detect_profile so per-target doctor checks
# mirror what the runner actually dispatches to at pre-push time.
_touchstone_detect_profile_dir() {
  local dir="$1"
  if [ -f "$dir/pnpm-workspace.yaml" ]; then
    printf 'node\n'
  elif [ -f "$dir/package.json" ] || [ -f "$dir/tsconfig.json" ]; then
    printf 'node\n'
  elif [ -f "$dir/Cargo.toml" ]; then
    printf 'rust\n'
  elif [ -f "$dir/Package.swift" ]; then
    printf 'swift\n'
  elif [ -f "$dir/go.mod" ]; then
    printf 'go\n'
  elif [ -f "$dir/uv.lock" ] || [ -f "$dir/pyproject.toml" ] || [ -f "$dir/requirements.txt" ]; then
    printf 'python\n'
  else
    printf 'generic\n'
  fi
}

# Normalize profile aliases to the canonical names the doctor check helpers
# switch on. Mirrors the set scripts/touchstone-run.sh:run_profile_action
# actually accepts — only typescript/ts map to node; run_profile_action
# rejects py/rs/golang as unknown (those aliases only exist at the
# new-project.sh input layer, never in a live .touchstone-config).
_touchstone_normalize_profile() {
  case "$1" in
    typescript|ts) printf 'node\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

# Iterate over targets (format: name:path:profile,name:path:profile,...) and
# invoke the given check function for each. The check function is called with
# (absolute_target_dir, target_profile, "target NAME: ").
_touchstone_doctor_foreach_target() {
  local project_dir="$1" targets_csv="$2" check_fn="$3"
  local entry name rest target_path target_profile target_dir
  local -a entries=()

  IFS=',' read -r -a entries <<< "$targets_csv"
  for entry in "${entries[@]}"; do
    entry="${entry#"${entry%%[![:space:]]*}"}"
    entry="${entry%"${entry##*[![:space:]]}"}"
    [ -z "$entry" ] && continue
    name="${entry%%:*}"
    rest="${entry#*:}"
    target_path="${rest%%:*}"
    target_profile="${rest#*:}"
    # When only two fields are present (no explicit profile), rest%%:* and
    # rest#*: both return the same string — treat as empty so auto-detect fires.
    [ "$target_profile" = "$target_path" ] && target_profile=""

    if [[ "$target_path" = /* ]]; then
      target_dir="$target_path"
    else
      target_dir="$project_dir/$target_path"
    fi

    if [ ! -d "$target_dir" ]; then
      tk_warn "target '$name' path not found: $target_path"
      issues=$((issues + 1))
      continue
    fi

    # Auto-detect + alias-normalize so targets like "web:apps/web:auto" or
    # "web:apps/web:ts" are checked against the same profile touchstone-run.sh
    # would dispatch to — otherwise doctor reports green on a target whose
    # lint/test gaps the runner actually exercises.
    if [ -z "$target_profile" ] || [ "$target_profile" = "auto" ]; then
      target_profile="$(_touchstone_detect_profile_dir "$target_dir")"
    fi
    target_profile="$(_touchstone_normalize_profile "$target_profile")"

    # Same validity gate as the root profile — touchstone-run.sh warns and
    # returns 1 on an unknown target profile, so doctor must flag it here.
    if ! _touchstone_profile_is_valid "$target_profile"; then
      tk_warn "target '$name': unknown profile '$target_profile' — touchstone-run.sh will reject it"
      issues=$((issues + 1))
      continue
    fi

    "$check_fn" "$target_dir" "$target_profile" "target ${name}: "
  done
}

# Per-profile test-presence check. Writes one line to the doctor output.
# Does not increment issues — missing tests are informational, not blocking.
# Always returns 0 so set -e in the caller doesn't halt on the final guard.
_touchstone_doctor_check_tests() {
  local dir="$1" profile="$2" label="$3"
  if _touchstone_profile_has_tests "$profile" "$dir"; then
    tk_ok "${label}tests: found for profile '$profile'"
  elif [ "$profile" = "generic" ]; then
    tk_dim "${label}tests: profile is 'generic' — touchstone runs whatever test_command you set"
  else
    tk_dim "${label}tests: not found for profile '$profile' (runner will skip, not fail)"
    if [ -z "$label" ]; then
      tk_dim "  See: touchstone run test  |  create one test to get real coverage"
    fi
  fi
  return 0
}

# Per-profile lint tool check. Increments caller's `issues` var when a real gap
# is detected (relies on dynamic-scope inheritance of locals; the caller is
# cmd_doctor_project which declares `local issues=0`).
# Always returns 0 so set -e in the caller doesn't halt on the final guard.
_touchstone_doctor_check_lint() {
  local dir="$1" profile="$2" label="$3"
  case "$profile" in
    python)
      if command -v ruff >/dev/null 2>&1; then
        tk_ok "${label}ruff: on PATH"
      else
        tk_warn "${label}ruff not on PATH — lint silently skips on every pre-push"
        tk_dim "  Fix: brew install ruff   (or: uv tool install ruff)"
        issues=$((issues + 1))
      fi
      ;;
    node)
      if [ -f "$dir/package.json" ] && grep -q '"lint"[[:space:]]*:' "$dir/package.json"; then
        tk_ok "${label}package.json: lint script configured"
      else
        tk_dim "${label}package.json has no 'lint' script — lint silently skips on every pre-push"
        if [ -z "$label" ]; then
          tk_dim "  Fix: add a \"lint\" entry under \"scripts\" in package.json"
        fi
      fi
      ;;
    swift)
      if command -v swift-format >/dev/null 2>&1; then
        tk_ok "${label}swift-format: on PATH"
      else
        tk_warn "${label}swift-format not on PATH — lint silently skips on every pre-push"
        tk_dim "  Fix: brew install swift-format"
        issues=$((issues + 1))
      fi
      ;;
    rust|go|generic|*)
      : # rust tools ship with rustup; go vet is built-in; generic has no default
      ;;
  esac
  return 0
}

# Profile-aware test-presence heuristic. Matches typical layout conventions
# without running the language's test discovery — speed matters here, and the
# check is a nudge, not an authoritative answer.
#
# Every profile's check must look for test FILES, never just the convention
# directory — an empty tests/ (or one with only helpers) is not tests.
# Reporting an empty directory as "tests found" would preserve the silent-skip
# gap this check exists to close.
_touchstone_profile_has_tests() {
  local profile="$1" dir="$2" matches
  case "$profile" in
    python)
      matches="$(find "$dir" -maxdepth 3 -type f \
        \( -name 'test_*.py' -o -name '*_test.py' \) -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    node)
      # Kept in sync with bootstrap/new-project.sh:_profile_has_any_tests_node.
      # Covers .test.{ts,tsx,js,jsx} and .spec.{ts,tsx,js,jsx} — React/TS
      # projects commonly declare "*.spec.tsx" files under src/.
      matches="$(find "$dir" -maxdepth 4 -type f \
        \( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.js' -o -name '*.test.jsx' \
           -o -name '*.spec.ts' -o -name '*.spec.tsx' -o -name '*.spec.js' -o -name '*.spec.jsx' \) \
        -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    rust)
      # Rust: tests/*.rs are integration tests; #[test] attributes live in src/.
      matches="$(find "$dir/tests" -maxdepth 2 -type f -name '*.rs' -print -quit 2>/dev/null || true)"
      [ -n "$matches" ] && return 0
      [ -d "$dir/src" ] && grep -rlq '#\[test\]' "$dir/src" 2>/dev/null
      ;;
    swift)
      matches="$(find "$dir/Tests" -maxdepth 3 -type f -name '*.swift' -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    go)
      matches="$(find "$dir" -maxdepth 4 -type f -name '*_test.go' -print -quit 2>/dev/null || true)"
      [ -n "$matches" ]
      ;;
    generic|*)
      return 1 # caller handles the 'generic' case before the not-found branch
      ;;
  esac
}

cmd_doctor() {
  local project_mode=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project) project_mode=true; shift ;;
      -h|--help)
        echo "Usage: touchstone doctor [--project]"
        echo "  (no flag)   Check touchstone installation health (CLI, tools, projects)"
        echo "  --project   Check per-project health (hooks, manifest, registry)"
        return 0
        ;;
      *) echo "ERROR: unknown argument '$1'" >&2; exit 1 ;;
    esac
  done

  if [ "$project_mode" = true ]; then
    cmd_doctor_project
    return $?
  fi

  local version
  version="$(touchstone_version_str)"
  local issues=0

  tk_header "Touchstone Doctor"

  # Version.
  if [ -n "$version" ]; then
    tk_ok "Version: v${version}"
  else
    tk_fail "Version: MISSING"
    issues=$((issues + 1))
  fi

  # Required tools.
  for tool in git gh bash; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_fail "$tool: MISSING"
      issues=$((issues + 1))
    fi
  done

  # Recommended tools.
  for tool in pre-commit gitleaks shellcheck shfmt; do
    if command -v "$tool" >/dev/null 2>&1; then
      tk_ok "$tool: $(command -v "$tool")"
    else
      tk_warn "$tool: not installed (run setup.sh to install)"
      issues=$((issues + 1))
    fi
  done

  # Optional tools.
  if command -v conductor >/dev/null 2>&1; then
    # Touchstone 2.0 delegates all review to conductor; richer status
    # lives in `conductor doctor`.
    if conductor doctor --json 2>/dev/null | grep -q '"configured"[[:space:]]*:[[:space:]]*true'; then
      tk_ok "conductor: $(command -v conductor) (at least one provider configured)"
    else
      tk_warn "conductor: $(command -v conductor) (no provider configured — run: conductor init)"
      issues=$((issues + 1))
    fi
  else
    tk_dim "conductor: not installed (optional — brew install autumngarage/conductor/conductor)"
  fi
  if command -v but >/dev/null 2>&1; then
    tk_ok "but: $(command -v but)"
  else
    tk_dim "but: not installed (optional — GitButler CLI for stacked branches and AI-agent savepoints)"
  fi

  # Registered projects.
  tk_info "Projects"
  local projects_file="$HOME/.touchstone-projects"
  local current_id
  current_id="$(touchstone_current_id)"
  if [ -f "$projects_file" ]; then
    while IFS= read -r project_dir; do
      [ -z "$project_dir" ] && continue
      [[ "$project_dir" == \#* ]] && continue
      if [ -d "$project_dir" ]; then
        local proj_version
        proj_version="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
        local name
        name="$(basename "$project_dir")"
        if [ "$proj_version" = "$current_id" ]; then
          tk_ok "$name — up to date"
        else
          tk_warn "$name — needs sync (run: touchstone sync)"
          issues=$((issues + 1))
        fi
      else
        tk_fail "$project_dir — directory not found"
        issues=$((issues + 1))
      fi
    done < "$projects_file"
  else
    tk_dim "No projects registered yet."
  fi

  # Latest release check.
  tk_info "Latest release"
  local latest
  latest="$(curl -fsSL --max-time 5 \
    "https://api.github.com/repos/autumngarage/touchstone/releases/latest" 2>/dev/null \
    | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/')" || latest=""
  if [ -n "$latest" ]; then
    if [ "$version" = "$latest" ]; then
      tk_ok "v${latest} — you're current"
    else
      tk_warn "v${latest} available (you have v${version}). Run: brew upgrade touchstone"
      issues=$((issues + 1))
    fi
  else
    tk_dim "Couldn't check (network issue?)"
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    tk_ok "All good."
  else
    tk_warn "$issues issue(s) found."
  fi
  echo ""
}

cmd_list() {
  local projects_file="$HOME/.touchstone-projects"
  local current_id
  current_id="$(touchstone_current_id)"

  tk_header "Registered Projects"

  if [ ! -f "$projects_file" ] || [ ! -s "$projects_file" ]; then
    tk_dim "No projects registered. Run: touchstone new <dir>"
    return
  fi

  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    [[ "$project_dir" == \#* ]] && continue
    local name
    name="$(basename "$project_dir")"
    if [ -d "$project_dir" ]; then
      local proj_version
      proj_version="$(cat "$project_dir/.touchstone-version" 2>/dev/null | tr -d '[:space:]' || echo "none")"
      if [ "$proj_version" = "$current_id" ]; then
        tk_ok "$name  ${DIM}$project_dir${RESET}"
      else
        tk_warn "$name  ${DIM}$project_dir${RESET}  ${YELLOW}(needs sync)${RESET}"
      fi
    else
      tk_fail "$name  ${DIM}$project_dir${RESET}  ${RED}(not found)${RESET}"
    fi
  done < "$projects_file"
  echo ""
}

cmd_unregister() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: touchstone unregister <project-path-or-name>" >&2
    exit 1
  fi

  local projects_file="$HOME/.touchstone-projects"
  if [ ! -f "$projects_file" ]; then
    tk_fail "No projects file found."
    return 1
  fi

  # Match by full path or basename.
  local matched=false
  local tmp_file
  tmp_file="$(mktemp)"
  while IFS= read -r project_dir; do
    [ -z "$project_dir" ] && continue
    if [ "$project_dir" = "$target" ] || [ "$(basename "$project_dir")" = "$target" ]; then
      tk_ok "Unregistered: $project_dir"
      matched=true
    else
      echo "$project_dir" >> "$tmp_file"
    fi
  done < "$projects_file"
  mv "$tmp_file" "$projects_file"

  if [ "$matched" = false ]; then
    tk_fail "No project matching '$target' found in registry."
    return 1
  fi
}

cmd_diff() {
  tk_header "Template Diff"
  tk_dim "Comparing project files against latest touchstone templates"
  echo ""

  local has_diff=false
  local pairs=(
    "CLAUDE.md:templates/CLAUDE.md"
    "AGENTS.md:templates/AGENTS.md"
    "GEMINI.md:templates/GEMINI.md"
    ".pre-commit-config.yaml:templates/pre-commit-config.yaml"
    ".codex-review.toml:hooks/codex-review.config.example.toml"
  )

  for pair in "${pairs[@]}"; do
    local project_file="${pair%%:*}"
    local template_file="${pair##*:}"
    local template_path="$TOUCHSTONE_ROOT/$template_file"

    if [ ! -f "$project_file" ]; then
      tk_dim "$project_file — not found (skipped)"
      continue
    fi
    if [ ! -f "$template_path" ]; then
      continue
    fi

    if diff -q "$project_file" "$template_path" >/dev/null 2>&1; then
      tk_ok "$project_file — matches template"
    else
      has_diff=true
      echo "${BOLD}--- $project_file (project)${RESET}"
      echo "${BOLD}+++ $template_file (touchstone template)${RESET}"
      diff -u "$project_file" "$template_path" 2>/dev/null | tail -n +3 || true
      echo ""
    fi
  done

  if [ "$has_diff" = false ]; then
    tk_ok "All project-owned files match templates."
  fi
  echo ""
}

cmd_adr() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      tk_header "Architecture Decision Records"
      if [ -d "docs/adr" ] && ls docs/adr/*.md >/dev/null 2>&1; then
        for f in docs/adr/[0-9]*.md; do
          local num title
          num="$(basename "$f" .md | grep -o '^[0-9]*')"
          title="$(head -1 "$f" | sed 's/^#* *//' | sed "s/^ADR-$num: //")"
          printf "  ${BOLD}ADR-%s${RESET}: %s\n" "$num" "$title"
        done
      else
        tk_dim "No ADRs found. Create one with: touchstone adr \"Title of decision\""
      fi
      echo ""
      ;;
    "")
      echo "Usage:" >&2
      echo "  touchstone adr \"Title of decision\"    Create a new ADR" >&2
      echo "  touchstone adr list                    List all ADRs" >&2
      exit 1
      ;;
    *)
      # Create a new ADR. The subcmd and remaining args form the title.
      local title="$subcmd $*"
      title="$(echo "$title" | sed 's/[[:space:]]*$//')"

      mkdir -p docs/adr

      # Find next number.
      local last_num=0
      if ls docs/adr/[0-9]*.md >/dev/null 2>&1; then
        last_num="$(ls docs/adr/[0-9]*.md | sed 's/.*\///' | grep -o '^[0-9]*' | sort -n | tail -1)"
      fi
      local next_num=$((10#$last_num + 1))
      local padded
      padded="$(printf "%04d" "$next_num")"

      local slug
      slug="$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')"
      local filename="docs/adr/${padded}-${slug}.md"

      local today
      today="$(date +%Y-%m-%d)"

      # Copy template and fill in.
      cp "$TOUCHSTONE_ROOT/templates/adr/0000-template.md" "$filename"
      sed -i '' "s/NNNN/$padded/g" "$filename"
      escaped_title="$(escape_sed_replacement "$title")"
      sed -i '' "s/TITLE/$escaped_title/g" "$filename"
      sed -i '' "s/DATE/$today/g" "$filename"

      tk_ok "Created: $filename"
      ;;
  esac
}

cmd_skills() {
  local subcmd="${1:-list}"

  case "$subcmd" in
    list)
      tk_header "Claude Code Skills"

      local found=false

      # Project-level skills.
      if [ -d ".claude/skills" ]; then
        for skill_dir in .claude/skills/*/; do
          [ -d "$skill_dir" ] || continue
          found=true
          local name
          name="$(basename "$skill_dir")"
          local status=""
          if [ -L "$skill_dir" ]; then
            local target
            target="$(readlink "$skill_dir")"
            status="${DIM}symlink → $target${RESET}"
          else
            status="${DIM}local${RESET}"
          fi
          if [ -f "${skill_dir}SKILL.md" ]; then
            printf "  ${GREEN}✓${RESET} ${BOLD}%-25s${RESET} project   %b\n" "$name" "$status"
          else
            printf "  ${RED}✗${RESET} ${BOLD}%-25s${RESET} project   %b ${RED}(missing SKILL.md)${RESET}\n" "$name" "$status"
          fi
        done
      fi

      # User-level skills.
      if [ -d "$HOME/.claude/skills" ]; then
        for skill_dir in "$HOME/.claude/skills"/*/; do
          [ -d "$skill_dir" ] || continue
          found=true
          local name
          name="$(basename "$skill_dir")"
          local status=""
          if [ -L "$skill_dir" ]; then
            local target
            target="$(readlink "$skill_dir")"
            status="${DIM}symlink → $target${RESET}"
          else
            status="${DIM}standalone (no symlink)${RESET}"
          fi
          if [ -f "${skill_dir}SKILL.md" ]; then
            printf "  ${GREEN}✓${RESET} ${BOLD}%-25s${RESET} user      %b\n" "$name" "$status"
          else
            printf "  ${RED}✗${RESET} ${BOLD}%-25s${RESET} user      %b ${RED}(missing SKILL.md)${RESET}\n" "$name" "$status"
          fi
        done
      fi

      if [ "$found" = false ]; then
        tk_dim "No skills found."
        tk_dim "Project skills:  .claude/skills/<name>/SKILL.md"
        tk_dim "User skills:     ~/.claude/skills/<name>/SKILL.md"
      fi
      echo ""
      ;;

    check)
      tk_header "Skill Validation"

      local issues=0
      local checked=0
      local dirs=()

      if [ -d ".claude/skills" ]; then
        for d in .claude/skills/*/; do [ -d "$d" ] && dirs+=("$d"); done
      fi
      if [ -d "$HOME/.claude/skills" ]; then
        for d in "$HOME/.claude/skills"/*/; do [ -d "$d" ] && dirs+=("$d"); done
      fi

      if [ "${#dirs[@]}" -eq 0 ]; then
        tk_dim "No skills found."
        echo ""
        return
      fi

      for skill_dir in "${dirs[@]}"; do
        checked=$((checked + 1))
        local name
        name="$(basename "$skill_dir")"
        local skill_file="${skill_dir}SKILL.md"

        if [ ! -f "$skill_file" ]; then
          tk_fail "$name — missing SKILL.md"
          issues=$((issues + 1))
          continue
        fi

        # Check frontmatter exists.
        if ! head -1 "$skill_file" | grep -q '^---$'; then
          tk_fail "$name — SKILL.md missing frontmatter (no leading ---)"
          issues=$((issues + 1))
          continue
        fi

        tk_ok "$name — valid"
      done

      echo ""
      if [ "$issues" -eq 0 ]; then
        tk_ok "All $checked skills valid."
      else
        tk_warn "$issues/$checked skills have issues."
      fi
      echo ""
      ;;

    *)
      echo "Usage:" >&2
      echo "  touchstone skills           List all skills" >&2
      echo "  touchstone skills check     Validate skill files" >&2
      exit 1
      ;;
  esac
}

cmd_release() {
  source "$TOUCHSTONE_ROOT/lib/release.sh"

  local bump_type="minor"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --major) bump_type="major"; shift ;;
      --minor) bump_type="minor"; shift ;;
      --patch) bump_type="patch"; shift ;;
      *) echo "Usage: touchstone release [--major|--minor|--patch]" >&2; exit 1 ;;
    esac
  done

  touchstone_release "$bump_type"
}

cmd_changelog() {
  local count="${1:-10}"
  tk_header "Recent Releases"

  if ! command -v gh >/dev/null 2>&1; then
    tk_fail "gh CLI not installed. Run: brew install gh"
    return 1
  fi

  gh release list --repo autumngarage/touchstone --limit "$count" 2>/dev/null || {
    tk_fail "Couldn't fetch releases (network issue or auth problem)."
    tk_dim "Fallback — recent commits:"
    git -C "$TOUCHSTONE_ROOT" log --oneline -"$count" 2>/dev/null || true
  }
  echo ""
}

cmd_help() {
  tk_header "touchstone — shared engineering starter kit"
  echo "  ${BOLD}Project commands:${RESET}"
  printf "    ${BOLD}touchstone init${RESET} [--no-setup]      Add touchstone to the current project\n"
  printf "    ${BOLD}touchstone init${RESET} --review-routing small-local  Use local review for small diffs\n"
  printf "    ${BOLD}touchstone init${RESET} --gitbutler       Add optional GitButler workflow setup\n"
  printf "    ${BOLD}touchstone new${RESET} <dir>              Bootstrap a new project from scratch\n"
  printf "    ${BOLD}touchstone detect${RESET}                 Show detected project profile\n"
  printf "    ${BOLD}touchstone run${RESET} <task>             Run lint, typecheck, build, test, or validate\n"
  printf "    ${BOLD}touchstone update${RESET}                 Create a branch + commit for touchstone updates\n"
  printf "    ${BOLD}touchstone update${RESET} --in-place      Commit touchstone updates on the current branch\n"
  printf "    ${BOLD}touchstone update${RESET} --dry-run       Preview what would change\n"
  printf "    ${BOLD}touchstone update${RESET} --check         Report whether this project needs update\n"
  printf "    ${BOLD}touchstone update${RESET} --ship          Push, open PR, review, and auto-merge\n"
  printf "    ${BOLD}touchstone migrate-from-toolkit${RESET}   One-shot rename of legacy .toolkit-* files (pre-1.0.0 projects)\n"
  printf "    ${BOLD}touchstone migrate-review-config${RESET}  Rewrite .codex-review.toml from 1.x → 2.0 shape (silences migration warnings on push)\n"
  printf "    ${BOLD}touchstone review --dry-run${RESET}      Preview which provider would review the next push, no tokens spent\n"
  printf "    ${BOLD}touchstone sync${RESET}                   Update all registered projects\n"
  printf "    ${BOLD}touchstone sync${RESET} --check           Report which projects need sync\n"
  printf "    ${BOLD}touchstone sync${RESET} --pull-first      Pull latest touchstone first\n"
  printf "    ${BOLD}touchstone diff${RESET}                   Compare project files vs templates\n"
  printf "    ${BOLD}touchstone adr${RESET} \"Title\"            Create an Architecture Decision Record\n"
  printf "    ${BOLD}touchstone adr${RESET} list               List all ADRs\n"
  echo ""
  echo "  ${BOLD}Registry commands:${RESET}"
  printf "    ${BOLD}touchstone list${RESET}                   Show registered projects\n"
  printf "    ${BOLD}touchstone unregister${RESET} <name>      Remove a project from registry\n"
  printf "    ${BOLD}touchstone status${RESET}                 Show status of the current project\n"
  printf "    ${BOLD}touchstone status${RESET} --all           Version distribution across registered projects\n"
  echo ""
  echo "  ${BOLD}Touchstone commands:${RESET}"
  printf "    ${BOLD}touchstone doctor${RESET}                 Check installation health\n"
  printf "    ${BOLD}touchstone doctor${RESET} --project       Check per-project health (hooks, manifest, registry)\n"
  printf "    ${BOLD}touchstone version${RESET}                Show installed version\n"
  printf "    ${BOLD}touchstone changelog${RESET} [N]          Show last N releases (default 10)\n"
  printf "    ${BOLD}touchstone skills${RESET}                 List Claude Code skills\n"
  printf "    ${BOLD}touchstone skills${RESET} check           Validate skill files\n"
  printf "    ${BOLD}touchstone release${RESET} [--patch]      Cut a new touchstone release\n"
  printf "    ${BOLD}touchstone help${RESET}                   Show this help\n"
  echo ""
  printf "  Install: ${DIM}brew tap autumngarage/touchstone && brew install touchstone${RESET}\n"
  echo ""
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  new)          cmd_new "$@" ;;
  init)         cmd_init "$@" ;;
  run)          cmd_run "$@" ;;
  detect)       cmd_detect ;;
  update)       cmd_update "$@" ;;
  migrate-from-toolkit) cmd_migrate_from_toolkit "$@" ;;
  migrate-review-config) cmd_migrate_review_config "$@" ;;
  review)       cmd_review "$@" ;;
  sync)         cmd_sync "$@" ;;
  status)       cmd_status "$@" ;;
  list|ls)      cmd_list ;;
  unregister)   cmd_unregister "$@" ;;
  diff)         cmd_diff ;;
  adr)          cmd_adr "$@" ;;
  skills)       cmd_skills "$@" ;;
  changelog)    cmd_changelog "$@" ;;
  release)      cmd_release "$@" ;;
  version)      cmd_version ;;
  doctor)       cmd_doctor "$@" ;;
  help|-h|--help) cmd_help ;;
  *)
    printf "${RED}Unknown command: $COMMAND${RESET}\n" >&2
    echo "Run 'touchstone help' for usage." >&2
    exit 1
    ;;
esac
